  </link>
  <joint name="left_to_top" type="fixed">
    <origin xyz="0 0 0.029" rpy="0 0 0" />
    <parent link="left_upright" />
    <child link="top_bar" />
  </joint>
  <joint name="left_to_bottom" type="fixed">
    <origin xyz="0 0 -0.029" rpy="0 0 0" />
    <parent link="left_upright" />
    <child link="bottom_bar" />
  </joint>
  <joint name="top_to_right" type="fixed">
    <origin xyz="0.104 0 0" rpy="0 0 0" />
    <parent link="top_bar" />
    <child link="right_upright" />
  </joint>
  <joint name="frame_to_rotor" type="revolute">
    <parent link="left_upright" />
    <child link="rotor" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="4" lower="-1.5708" upper="1.5708" />
  </joint>
</robot>