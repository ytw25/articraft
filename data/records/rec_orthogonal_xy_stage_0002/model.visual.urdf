<robot name="compact_cartesian_stage">
  <material name="machined_aluminum">
    <color rgba="0.78 0.8 0.83 1" />
    </material>
  <material name="anodized_blue">
    <color rgba="0.19 0.32 0.62 1" />
    </material>
  <material name="rail_steel">
    <color rgba="0.56 0.58 0.61 1" />
    </material>
  <material name="bearing_black">
    <color rgba="0.12 0.13 0.15 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <mass value="2.6" />
      <inertia ixx="0.00710667" ixy="0" ixz="0" iyy="0.0170733" iyz="0" izz="0.0240067" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_plate.obj" />
        </geometry>
      <material name="machined_aluminum" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/x_rails.obj" />
        </geometry>
      <material name="rail_steel" />
      </visual>
    </link>
  <link name="x_stage">
    <inertial>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <mass value="1.3" />
      <inertia ixx="0.00191577" ixy="0" ixz="0" iyy="0.00220827" iyz="0" izz="0.00395417" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/x_carriage_plate.obj" />
        </geometry>
      <material name="anodized_blue" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/x_bearing_blocks.obj" />
        </geometry>
      <material name="bearing_black" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_rails.obj" />
        </geometry>
      <material name="rail_steel" />
      </visual>
    </link>
  <link name="y_stage">
    <inertial>
      <origin xyz="0 0 0.013" rpy="0 0 0" />
      <mass value="0.85" />
      <inertia ixx="0.000756217" ixy="0" ixz="0" iyy="0.00106788" iyz="0" izz="0.00172833" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_stage_plate.obj" />
        </geometry>
      <material name="machined_aluminum" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_bearing_blocks.obj" />
        </geometry>
      <material name="bearing_black" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/tool_mount.obj" />
        </geometry>
      <material name="rail_steel" />
      </visual>
    </link>
  <joint name="x_slide" type="prismatic">
    <origin xyz="0 0 0.014" rpy="0 0 0" />
    <parent link="base" />
    <child link="x_stage" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.25" lower="-0.06" upper="0.06" />
    </joint>
  <joint name="y_slide" type="prismatic">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="x_stage" />
    <child link="y_stage" />
    <axis xyz="0 1 0" />
    <limit effort="60" velocity="0.25" lower="-0.045" upper="0.045" />
    </joint>
  </robot>
