<robot name="linear_positioning_rotary_elbow_module">
  <material name="steel">
    <color rgba="0.66 0.68 0.72 1" />
  </material>
  <material name="anodized">
    <color rgba="0.36 0.39 0.43 1" />
  </material>
  <material name="cover_black">
    <color rgba="0.15 0.16 0.18 1" />
  </material>
  <material name="tool_red">
    <color rgba="0.78 0.16 0.14 1" />
  </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="0 0 0.012" rpy="0 0 0" />
      <mass value="7.2" />
      <inertia ixx="0.023775" ixy="0" ixz="0" iyy="0.315375" iyz="0" izz="0.33048" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_frame_main.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/base_frame_covers.glb" />
      </geometry>
      <material name="cover_black" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.72 0.18 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.54 0.026 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.055 0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.58 0.018 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.58 0.018 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.31 0 0.03" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.14 0.06" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.315 0 0.0225" rpy="0 0 0" />
      <geometry>
        <box size="0.075 0.1 0.045" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <mass value="1.9" />
      <inertia ixx="0.00248583" ixy="0" ixz="0" iyy="0.00514583" iyz="0" izz="0.00649167" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage_main.glb" />
      </geometry>
      <material name="anodized" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage_cover.glb" />
      </geometry>
      <material name="cover_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.17 0.11 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.042 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.022 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.042 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.022 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.031" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.038" length="0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.048" rpy="0 0 0" />
      <geometry>
        <box size="0.094 0.094 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="elbow_stage">
    <inertial>
      <origin xyz="0.14 0 0.035" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00218667" ixy="0" ixz="0" iyy="0.0145067" iyz="0" izz="0.0149867" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/elbow_main.glb" />
      </geometry>
      <material name="anodized" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/elbow_cover.glb" />
      </geometry>
      <material name="cover_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.06 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.07 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.19 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.05 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="extension_inner">
    <inertial>
      <origin xyz="0.15 0 0" rpy="0 0 0" />
      <mass value="0.9" />
      <inertia ixx="0.00123" ixy="0" ixz="0" iyy="0.0075" iyz="0" izz="0.00723" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/extension_main.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/extension_tool.glb" />
      </geometry>
      <material name="tool_red" />
    </visual>
    <collision>
      <origin xyz="0.12 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.036 0.036" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.246 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.08 0.08" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.279 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.032 0.1" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_carriage" type="prismatic">
    <origin xyz="0 0 0.026" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="0.4" lower="-0.17" upper="0.18" />
  </joint>
  <joint name="carriage_to_elbow" type="revolute">
    <origin xyz="0 0 0.052" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="elbow_stage" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="2" lower="-1.2" upper="1.2" />
  </joint>
  <joint name="elbow_to_extension" type="prismatic">
    <origin xyz="0.11 0 0.025" rpy="0 0 0" />
    <parent link="elbow_stage" />
    <child link="extension_inner" />
    <axis xyz="1 0 0" />
    <limit effort="90" velocity="0.25" lower="0" upper="0.16" />
  </joint>
</robot>