<robot name="motorized_roll_stage">
  <material name="machined_aluminum">
    <color rgba="0.76 0.78 0.81 1" />
  </material>
  <material name="motor_black">
    <color rgba="0.18 0.19 0.21 1" />
  </material>
  <material name="tube_black">
    <color rgba="0.12 0.13 0.15 1" />
  </material>
  <material name="signal_amber">
    <color rgba="0.87 0.52 0.12 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.043" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00206613" ixy="0" ixz="0" iyy="0.00866613" iyz="0" izz="0.00876" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/roll_stage_base_frame.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/roll_stage_motor.glb" />
      </geometry>
      <material name="motor_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.09 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.075 0 0.0245" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.055 0.025" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.075 0 0.0805" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.04675 0.011" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.075 0 0.0245" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.055 0.025" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.075 0 0.0805" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.04675 0.011" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.115 0 0.056" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.046 0.046" />
      </geometry>
    </collision>
  </link>
  <link name="sensor_tube">
    <inertial>
      <origin xyz="0.075 0 0" rpy="0 1.5708 0" />
      <mass value="0.42" />
      <inertia ixx="0.00083832" ixy="0" ixz="0" iyy="0.00083832" iyz="0" izz="0.00010164" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/sensor_tube_body.glb" />
      </geometry>
      <material name="tube_black" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/sensor_tube_flag.glb" />
      </geometry>
      <material name="signal_amber" />
    </visual>
    <collision>
      <origin xyz="0.086 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.016" length="0.196" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.075 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.022" length="0.094" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.084 0 0.028" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.018 0.022" />
      </geometry>
    </collision>
  </link>
  <joint name="tube_roll" type="revolute">
    <origin xyz="-0.075 0 0.056" rpy="0 0 0" />
    <parent link="base" />
    <child link="sensor_tube" />
    <axis xyz="1 0 0" />
    <limit effort="6" velocity="2.5" lower="-1.2" upper="1.2" />
  </joint>
</robot>