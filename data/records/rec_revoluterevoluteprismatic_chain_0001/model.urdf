    </collision>
    <collision>
      <origin xyz="0.12 0.012 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.006 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.12 -0.012 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.006 0.028" />
      </geometry>
    </collision>
  </link>
  <link name="tool_slide">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="8e-05" ixy="0" ixz="0" iyy="0.00104" iyz="0" izz="0.00104" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_slide.glb" />
      </geometry>
      <material name="anodized_dark" />
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.016 0.026" />
