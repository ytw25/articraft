      <mass value="0.9" />
      <inertia ixx="0.0003075" ixy="0" ixz="0" iyy="0.002355" iyz="0" izz="0.0022875" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="aluminum" />
    </visual>
    <visual>
      <origin xyz="0.17 -0.022 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.022" length="0.006" />
