  </link>
  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.153" rpy="0 0 0" />
    <parent link="bench_base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="2.5" lower="0" upper="1.15" />
  </joint>
  <joint name="elbow_joint" type="revolute">
    <origin xyz="0.17 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="2.8" lower="-0.45" upper="1.25" />
  </joint>
  <joint name="telescoping_slide" type="prismatic">
    <origin xyz="0.095 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_slide" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="0.4" lower="0" upper="0.1" />
  </joint>
</robot>