<robot name="bench_manipulator">
  <material name="aluminum">
    <color rgba="0.76 0.78 0.8 1" />
  </material>
  <material name="bearing_dark">
    <color rgba="0.2 0.22 0.26 1" />
  </material>
  <material name="anodized_dark">
    <color rgba="0.28 0.3 0.34 1" />
