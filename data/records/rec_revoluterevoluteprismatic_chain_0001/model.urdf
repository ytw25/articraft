      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.153" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.022" length="0.014" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
