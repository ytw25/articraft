      <origin xyz="0 0 0.07" rpy="0 0 0" />
      <mass value="5" />
      <inertia ixx="0.0141667" ixy="0" ixz="0" iyy="0.0216667" iyz="0" izz="0.0195" />
    </inertial>
    <visual>
