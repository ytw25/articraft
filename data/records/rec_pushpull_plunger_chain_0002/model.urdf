<robot name="chained_plunger_mechanism">
  <material name="frame_steel">
    <color rgba="0.63 0.66 0.72 1" />
  </material>
  <material name="dark_anodized">
    <color rgba="0.2 0.22 0.26 1" />
  </material>
  <material name="plunger_finish">
    <color rgba="0.86 0.88 0.9 1" />
  </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00216" ixy="0" ixz="0" iyy="0.00269333" iyz="0" izz="0.00269333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_frame.glb" />
      </geometry>
      <material name="frame_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.09 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.035 0 0.0175" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.05 0.055" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.035 0 0.0175" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.05 0.055" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.027 0 0.063" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.06 0.13" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.027 0 0.063" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.06 0.13" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.027 0.063" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.006 0.13" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.027 0.063" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.006 0.13" />
      </geometry>
    </collision>
  </link>
  <link name="carrier_slide">
    <inertial>
      <origin xyz="0 0 0.085" rpy="0 0 0" />
      <mass value="0.42" />
      <inertia ixx="0.000875" ixy="0" ixz="0" iyy="0.000875" iyz="0" izz="0.000175" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carrier_slide.glb" />
      </geometry>
      <material name="dark_anodized" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0375" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0195" length="0.075" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.015 0 0.1175" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.034 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.015 0 0.1175" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.034 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.015 0.1175" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.004 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.015 0.1175" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.004 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.078" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.022 0.014" />
      </geometry>
    </collision>
  </link>
  <link name="plunger_rod">
    <inertial>
      <origin xyz="0 0 0.085" rpy="0 0 0" />
      <mass value="0.19" />
      <inertia ixx="0.000463331" ixy="0" ixz="0" iyy="0.000463331" iyz="0" izz="1.1495e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/plunger_rod.glb" />
      </geometry>
      <material name="plunger_finish" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0725" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0085" length="0.145" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.155" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.026 0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_carrier" type="prismatic">
    <parent link="base_frame" />
    <child link="carrier_slide" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.25" lower="0" upper="0.06" />
  </joint>
  <joint name="carrier_to_plunger" type="prismatic">
    <origin xyz="0 0 0.085" rpy="0 0 0" />
    <parent link="carrier_slide" />
    <child link="plunger_rod" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="0.3" lower="0" upper="0.055" />
  </joint>
</robot>