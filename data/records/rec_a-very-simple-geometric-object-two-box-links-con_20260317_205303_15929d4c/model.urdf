<robot name="simple_revolute_boxes">
  <material name="wood">
    <color rgba="0.6 0.4 0.2 1" />
    </material>
  <material name="metal">
    <color rgba="0.7 0.7 0.7 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="1" />
      <inertia ixx="0.000416667" ixy="0" ixz="0" iyy="0.00354167" iyz="0" izz="0.00354167" />
      </inertial>
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
        </geometry>
      <material name="wood">
        <color rgba="0.6 0.4 0.2 1" />
        </material>
      </visual>
    <visual name="pin">
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.06" />
        </geometry>
      <material name="metal">
        <color rgba="0.7 0.7 0.7 1" />
        </material>
      </visual>
    <collision name="base__visual_1">
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
        </geometry>
      </collision>
    <collision name="base__pin">
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.06" />
        </geometry>
      </collision>
    </link>
  <link name="moving">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.000208333" ixy="0" ixz="0" iyy="0.00177083" iyz="0" izz="0.00177083" />
      </inertial>
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
        </geometry>
      <material name="metal">
        <color rgba="0.7 0.7 0.7 1" />
        </material>
      </visual>
    <collision name="moving__visual_1">
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
        </geometry>
      </collision>
    </link>
  <joint name="joint" type="revolute">
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <parent link="base" />
    <child link="moving" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="5" lower="-1.57" upper="1.57" />
    </joint>
  </robot>
