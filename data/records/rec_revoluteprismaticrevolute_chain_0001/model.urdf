  <joint name="base_swivel" type="revolute">
    <origin xyz="0 0 0.13" rpy="0 0 0" />
    <parent link="base" />
    <child link="arm_outer" />
    <axis xyz="0 0 1" />
    <limit effort="50" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="mid_slide" type="prismatic">
    <origin xyz="0.135 0 0.047" rpy="0 0 0" />
    <parent link="arm_outer" />
    <child link="slide" />
    <axis xyz="1 0 0" />
    <limit effort="40" velocity="0.25" lower="0" upper="0.18" />
    </joint>
