<robot name="pedestal_yaw_module">
  <material name="motor_black">
    <color rgba="0.17 0.18 0.2 1" />
  </material>
  <material name="bearing_steel">
    <color rgba="0.52 0.54 0.58 1" />
  </material>
  <material name="plate_aluminum">
    <color rgba="0.76 0.78 0.8 1" />
  </material>
  <link name="pedestal_base">
    <inertial>
      <origin xyz="0 0 0.0615" rpy="0 0 0" />
      <mass value="2.4" />
      <inertia ixx="0.0069458" ixy="0" ixz="0" iyy="0.0069458" iyz="0" izz="0.00784" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pedestal_base.glb" />
      </geometry>
      <material name="motor_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.14 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.0675" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.032" length="0.055" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.0365 0.109" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.037 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.0365 0.109" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.037 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0365 0 0.109" rpy="0 0 0" />
      <geometry>
        <box size="0.037 0.036 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.0365 0 0.109" rpy="0 0 0" />
      <geometry>
        <box size="0.037 0.036 0.028" />
      </geometry>
    </collision>
  </link>
  <link name="yaw_rotor">
    <inertial>
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <mass value="0.35" />
      <inertia ixx="0.000190079" ixy="0" ixz="0" iyy="0.000190079" iyz="0" izz="0.0003087" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/yaw_rotor.glb" />
      </geometry>
      <material name="bearing_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.002" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.015" length="0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.042" length="0.01" />
      </geometry>
    </collision>
  </link>
  <link name="top_plate">
    <inertial>
      <origin xyz="0.01 0 0.006" rpy="0 0 0" />
      <mass value="0.55" />
      <inertia ixx="0.0014916" ixy="0" ixz="0" iyy="0.00183993" iyz="0" izz="0.00331833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/top_plate.glb" />
      </geometry>
      <material name="plate_aluminum" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.18 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.03 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="pedestal_to_rotor" type="revolute">
    <origin xyz="0 0 0.109" rpy="0 0 0" />
    <parent link="pedestal_base" />
    <child link="yaw_rotor" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="4" lower="-1.5708" upper="1.5708" />
  </joint>
  <joint name="rotor_to_top_plate" type="fixed">
    <origin xyz="0 0 0.025" rpy="0 0 0" />
    <parent link="yaw_rotor" />
    <child link="top_plate" />
  </joint>
</robot>