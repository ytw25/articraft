<robot name="simple_robot_arm">
  <material name="graphite">
    <color rgba="0.2 0.22 0.25 1" />
  </material>
  <material name="arm_paint">
    <color rgba="0.86 0.46 0.12 1" />
  </material>
  <material name="tool_steel">
    <color rgba="0.62 0.64 0.67 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.115" rpy="0 0 0" />
      <mass value="6" />
      <inertia ixx="0.03625" ixy="0" ixz="0" iyy="0.04645" iyz="0" izz="0.0298" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.14 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.115" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.1 0.15" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.2025" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.1 0.025" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.12 0 0" rpy="0 0 0" />
      <mass value="1.8" />
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.00918" iyz="0" izz="0.0096" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="arm_paint" />
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.07 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.12 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.17 0.05 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.225 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.065 0.03" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.000678333" ixy="0" ixz="0" iyy="0.00389583" iyz="0" izz="0.00411583" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="arm_paint" />
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.065 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.045 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.185 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.055 0.025" />
      </geometry>
    </collision>
  </link>
  <link name="tool_block">
    <inertial>
      <origin xyz="0.045 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="0.0001125" ixy="0" ixz="0" iyy="0.000225" iyz="0" izz="0.0002925" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_block.glb" />
      </geometry>
      <material name="tool_steel" />
    </visual>
    <collision>
      <origin xyz="0.01 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.05 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.045 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.085 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.025 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.23" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="25" velocity="1.5" lower="-0.4" upper="1.4" />
  </joint>
  <joint name="elbow_joint" type="revolute">
    <origin xyz="0.24 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.8" lower="0" upper="2.2" />
  </joint>
  <joint name="tool_mount" type="fixed">
    <origin xyz="0.2 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_block" />
  </joint>
</robot>