<robot name="pitch_axis_actuator_module">
  <material name="cast_aluminum">
    <color rgba="0.67 0.69 0.72 1" />
  </material>
  <material name="powdercoat_dark">
    <color rgba="0.2 0.21 0.24 1" />
  </material>
  <link name="actuator_base">
    <inertial>
      <mass value="1.8" />
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0024216" iyz="0" izz="0.0028416" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/actuator_base.glb" />
      </geometry>
      <material name="cast_aluminum" />
    </visual>
    <collision>
      <geometry>
        <box size="0.09 0.07 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.108 0.018 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.045 0 0.042" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.05 0.044" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.045 0 0.042" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.05 0.044" />
      </geometry>
    </collision>
  </link>
  <link name="payload_bracket">
    <inertial>
      <origin xyz="0 0.038 -0.006" rpy="0 0 0" />
      <mass value="0.65" />
      <inertia ixx="0.000693333" ixy="0" ixz="0" iyy="0.000785417" iyz="0" izz="0.000785417" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/payload_bracket.glb" />
      </geometry>
      <material name="powdercoat_dark" />
    </visual>
    <collision>
      <origin xyz="0 0.066 -0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.088 0.01 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.032 0.032 -0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.055 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.032 0.032 -0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.055 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.044 -0.002" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.038 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.018 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.008 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="pitch_joint" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="actuator_base" />
    <child link="payload_bracket" />
    <axis xyz="1 0 0" />
    <limit effort="18" velocity="2.5" lower="-1" upper="1.2" />
  </joint>
</robot>