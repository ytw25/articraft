<robot name="cantilevered_industrial_arm">
  <material name="support_gray">
    <color rgba="0.24 0.26 0.3 1" />
    </material>
  <material name="arm_orange">
    <color rgba="0.89 0.46 0.17 1" />
    </material>
  <material name="tool_dark">
    <color rgba="0.13 0.13 0.15 1" />
    </material>
  <link name="support">
    <inertial>
      <origin xyz="0.05 0 0.18" rpy="0 0 0" />
      <mass value="16" />
      <inertia ixx="0.184667" ixy="0" ixz="0" iyy="0.152667" iyz="0" izz="0.0642667" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/support.obj" />
        </geometry>
      <material name="support_gray" />
      </visual>
    </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.16 0 0" rpy="0 0 0" />
      <mass value="8" />
      <inertia ixx="0.0162667" ixy="0" ixz="0" iyy="0.0792667" iyz="0" izz="0.0822" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/upper_arm.obj" />
        </geometry>
      <material name="arm_orange" />
      </visual>
    </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.125 0 0" rpy="0 0 0" />
      <mass value="5" />
      <inertia ixx="0.00754167" ixy="0" ixz="0" iyy="0.03375" iyz="0" izz="0.0345417" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/forearm.obj" />
        </geometry>
      <material name="arm_orange" />
      </visual>
    </link>
  <link name="wrist">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="2.5" />
      <inertia ixx="0.00460417" ixy="0" ixz="0" iyy="0.0108542" iyz="0" izz="0.0104167" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/wrist.obj" />
        </geometry>
      <material name="tool_dark" />
      </visual>
    </link>
  <joint name="shoulder_swing" type="revolute">
    <origin xyz="0.075 0 0.18" rpy="0 0 0" />
    <parent link="support" />
    <child link="upper_arm" />
    <axis xyz="0 0 1" />
    <limit effort="420" velocity="1.2" lower="-0.35" upper="1.35" />
    </joint>
  <joint name="elbow_swing" type="revolute">
    <origin xyz="0.29 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 0 1" />
    <limit effort="280" velocity="1.6" lower="-1.1" upper="1.35" />
    </joint>
  <joint name="wrist_swing" type="revolute">
    <origin xyz="0.24 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="2" lower="-1" upper="1.15" />
    </joint>
  </robot>
