<robot name="cantilevered_industrial_arm">
  <material name="support_gray">
    <color rgba="0.24 0.26 0.3 1" />
  </material>
  <material name="arm_orange">
    <color rgba="0.89 0.46 0.17 1" />
  </material>
  <material name="tool_dark">
    <color rgba="0.13 0.13 0.15 1" />
  </material>
  <link name="support">
    <inertial>
      <origin xyz="0.05 0 0.18" rpy="0 0 0" />
      <mass value="16" />
      <inertia ixx="0.184667" ixy="0" ixz="0" iyy="0.152667" iyz="0" izz="0.0642667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/support.glb" />
      </geometry>
      <material name="support_gray" />
    </visual>
    <collision>
      <origin xyz="0.012 0 0.18" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.19 0.32" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.052 0 0.18" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.14 0.12" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.04 0 0.245" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.11 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.04 0 0.115" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.11 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.16 0 0" rpy="0 0 0" />
      <mass value="8" />
      <inertia ixx="0.0162667" ixy="0" ixz="0" iyy="0.0792667" iyz="0" izz="0.0822" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="arm_orange" />
    </visual>
    <collision>
      <origin xyz="0.03 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.12 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.15 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.21 0.08 0.065" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.29 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.1 0.09" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.125 0 0" rpy="0 0 0" />
      <mass value="5" />
      <inertia ixx="0.00754167" ixy="0" ixz="0" iyy="0.03375" iyz="0" izz="0.0345417" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="arm_orange" />
    </visual>
    <collision>
      <origin xyz="0.025 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.1 0.09" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.175 0.07 0.058" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.24 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.085 0.08" />
      </geometry>
    </collision>
  </link>
  <link name="wrist">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="2.5" />
      <inertia ixx="0.00460417" ixy="0" ixz="0" iyy="0.0108542" iyz="0" izz="0.0104167" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/wrist.glb" />
      </geometry>
      <material name="tool_dark" />
    </visual>
    <collision>
      <origin xyz="0.028 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.085 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.065 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.165 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.1 0.11" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_swing" type="revolute">
    <origin xyz="0.075 0 0.18" rpy="0 0 0" />
    <parent link="support" />
    <child link="upper_arm" />
    <axis xyz="0 0 1" />
    <limit effort="420" velocity="1.2" lower="-0.35" upper="1.35" />
  </joint>
  <joint name="elbow_swing" type="revolute">
    <origin xyz="0.29 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 0 1" />
    <limit effort="280" velocity="1.6" lower="-1.1" upper="1.35" />
  </joint>
  <joint name="wrist_swing" type="revolute">
    <origin xyz="0.24 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="2" lower="-1" upper="1.15" />
  </joint>
</robot>