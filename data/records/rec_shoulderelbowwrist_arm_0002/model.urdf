<robot name="lightweight_articulated_arm">
  <material name="graphite">
    <color rgba="0.2 0.22 0.26 1" />
  </material>
  <material name="alloy">
    <color rgba="0.74 0.76 0.8 1" />
  </material>
  <material name="accent">
    <color rgba="0.28 0.46 0.82 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.077" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.00407477" ixy="0" ixz="0" iyy="0.00407477" iyz="0" izz="0.0038016" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.072" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.057" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.031" length="0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.0265 0.125" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.017 0.058" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.0265 0.125" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.017 0.058" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.11 0 0" rpy="0 0 0" />
      <mass value="0.36" />
      <inertia ixx="0.000204" ixy="0" ixz="0" iyy="0.00180912" iyz="0" izz="0.00185088" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="alloy" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.028" length="0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.105 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.19 0.024 0.034" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.205 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.024 0.0306" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.22 0.024 0" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.016 0.052" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.22 -0.024 0" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.016 0.052" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <mass value="0.24" />
      <inertia ixx="0.00010144" ixy="0" ixz="0" iyy="0.0008228" iyz="0" izz="0.0008468" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="alloy" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.024" length="0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.082 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.148 0.022 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.166 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.022 0.0276" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.18 0.021 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.014 0.044" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.18 -0.021 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.014 0.044" />
      </geometry>
    </collision>
  </link>
  <link name="wrist">
    <inertial>
      <origin xyz="0.0425 0 0" rpy="0 0 0" />
      <mass value="0.14" />
      <inertia ixx="3.37867e-05" ixy="0" ixz="0" iyy="0.000102958" iyz="0" izz="9.94117e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/wrist.glb" />
      </geometry>
      <material name="accent" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.021" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.038 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.058 0.026 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.066 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.02132 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.079 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.018" length="0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.125" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="2" lower="-0.2" upper="1.25" />
  </joint>
  <joint name="elbow_joint" type="revolute">
    <origin xyz="0.22 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="8" velocity="2.4" lower="0" upper="1.9" />
  </joint>
  <joint name="wrist_joint" type="revolute">
    <origin xyz="0.18 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist" />
    <axis xyz="0 -1 0" />
    <limit effort="4" velocity="3" lower="-1" upper="1" />
  </joint>
</robot>