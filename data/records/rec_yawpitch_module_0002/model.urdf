      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.14 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.001 -0.06 0.0635" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.01 0.085" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.001 0.06 0.0635" rpy="0 0 0" />
