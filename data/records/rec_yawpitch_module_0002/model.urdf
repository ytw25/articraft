  <joint name="base_to_yaw" type="revolute">
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <parent link="base" />
    <child link="yaw_stage" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="2" lower="-2.6" upper="2.6" />
  </joint>
  <joint name="yaw_to_pitch" type="revolute">
    <origin xyz="0 -0.052 0.088" rpy="0 0 0" />
    <parent link="yaw_stage" />
    <child link="pitch_yoke" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="1.8" lower="-0.75" upper="1.05" />
  </joint>
