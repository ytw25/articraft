<robot name="two_axis_turret_module">
  <material name="base_paint">
    <color rgba="0.18 0.19 0.21 1" />
  </material>
  <material name="structure">
    <color rgba="0.33 0.35 0.39 1" />
  </material>
  <material name="payload">
    <color rgba="0.46 0.49 0.53 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <mass value="2.4" />
      <inertia ixx="0.0072" ixy="0" ixz="0" iyy="0.0072" iyz="0" izz="0.01296" />
