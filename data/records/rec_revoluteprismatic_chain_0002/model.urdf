<robot name="hinged_work_light">
  <material name="dark_body">
    <color rgba="0.16 0.17 0.19 1" />
  </material>
  <material name="arm_yellow">
    <color rgba="0.92 0.77 0.16 1" />
  </material>
  <material name="lamp_gray">
    <color rgba="0.67 0.69 0.72 1" />
  </material>
  <material name="lens">
    <color rgba="0.85 0.92 0.98 0.4" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <mass value="2.4" />
      <inertia ixx="0.0052" ixy="0" ixz="0" iyy="0.01096" iyz="0" izz="0.0136" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/work_light_base.glb" />
      </geometry>
      <material name="dark_body" />
    </visual>
    <collision>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.14 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.078 0 0.034" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.05 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.056 0.019 0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.008 0.054" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.056 -0.019 0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.008 0.054" />
      </geometry>
    </collision>
  </link>
  <link name="outer_arm">
    <inertial>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <mass value="0.65" />
      <inertia ixx="0.000173333" ixy="0" ixz="0" iyy="0.00225333" iyz="0" izz="0.00225333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/work_light_outer_arm.glb" />
      </geometry>
      <material name="arm_yellow" />
    </visual>
    <collision>
      <origin xyz="0.0925 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.185 0.022 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.012" length="0.01" />
      </geometry>
    </collision>
  </link>
  <link name="inner_slide">
    <inertial>
      <origin xyz="0.17 0 0.015" rpy="0 0 0" />
      <mass value="0.75" />
      <inertia ixx="0.00070625" ixy="0" ixz="0" iyy="0.0053" iyz="0" izz="0.00520625" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/work_light_slider.glb" />
      </geometry>
      <material name="arm_yellow" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/work_light_head.glb" />
      </geometry>
      <material name="lamp_gray" />
    </visual>
    <visual>
      <origin xyz="0.259 0 0.01" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.028" length="0.004" />
      </geometry>
      <material name="lens" />
    </visual>
    <collision>
      <origin xyz="0.095 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.19 0.018 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.205 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.026 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.235 0 0.01" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.034" length="0.044" />
      </geometry>
    </collision>
  </link>
  <joint name="base_tilt" type="revolute">
    <origin xyz="-0.056 0 0.062" rpy="0 0 0" />
    <parent link="base" />
    <child link="outer_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="1.2" lower="0" upper="1.25" />
  </joint>
  <joint name="arm_extension" type="prismatic">
    <origin xyz="0.04 0 0" rpy="0 0 0" />
    <parent link="outer_arm" />
    <child link="inner_slide" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="0.15" lower="0" upper="0.12" />
  </joint>
</robot>