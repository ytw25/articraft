<robot name="three_joint_robotic_arm">
  <material name="painted_steel">
    <color rgba="0.23 0.25 0.28 1" />
  </material>
  <material name="machined_aluminum">
    <color rgba="0.78 0.8 0.84 1" />
  </material>
  <material name="tool_black">
    <color rgba="0.12 0.12 0.14 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 -0.06" rpy="0 0 0" />
      <mass value="3" />
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.0113" iyz="0" izz="0.0085" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="painted_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.111" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.12 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.051" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.12" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.028 0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.012 0.055" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.028 0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.012 0.055" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.11 0 0" rpy="0 0 0" />
      <mass value="1.2" />
      <inertia ixx="0.00072" ixy="0" ixz="0" iyy="0.00612" iyz="0" izz="0.00612" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.028 0.048" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.02 0 -0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.05 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.104 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.036 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.182 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.032 0.035" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.21 0.019 0" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.01 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.21 -0.019 0" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.01 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.086 0 0" rpy="0 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.000333333" ixy="0" ixz="0" iyy="0.00232667" iyz="0" izz="0.00232667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.026 0.044" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.082 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.032 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.146 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.028 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.165 0.016 0" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.009 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.165 -0.016 0" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.009 0.04" />
      </geometry>
    </collision>
  </link>
  <link name="tool_flange">
    <inertial>
      <origin xyz="0.04 0 0" rpy="0 0 0" />
      <mass value="0.25" />
      <inertia ixx="0.000104167" ixy="0" ixz="0" iyy="0.000220833" iyz="0" izz="0.000220833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_flange.glb" />
      </geometry>
      <material name="tool_black" />
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.022 0.034" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.034 0.034" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.044 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.044 0.044" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.062 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.016 0.016" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_hinge" type="revolute">
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="40" velocity="1.5" lower="-0.55" upper="1.2" />
  </joint>
  <joint name="elbow_hinge" type="revolute">
    <origin xyz="0.21 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="28" velocity="1.8" lower="0" upper="1.75" />
  </joint>
  <joint name="wrist_hinge" type="revolute">
    <origin xyz="0.165 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_flange" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="2.2" lower="-1.1" upper="1.1" />
  </joint>
</robot>