<robot name="gantry_mounted_arm">
  <material name="frame_gray">
    <color rgba="0.36 0.38 0.42 1" />
  </material>
  <material name="carriage_orange">
    <color rgba="0.88 0.48 0.15 1" />
  </material>
  <material name="arm_blue">
    <color rgba="0.2 0.41 0.73 1" />
  </material>
  <material name="tool_black">
    <color rgba="0.15 0.15 0.17 1" />
  </material>
  <link name="gantry">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <mass value="14" />
      <inertia ixx="0.110396" ixy="0" ixz="0" iyy="0.606667" iyz="0" izz="0.713329" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/gantry.glb" />
      </geometry>
      <material name="frame_gray" />
    </visual>
    <collision>
      <origin xyz="0 0.13 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.72 0.045 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.13 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.72 0.045 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.33 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.305 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.33 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.305 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <geometry>
        <box size="0.52 0.085 0.024" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <mass value="2.4" />
      <inertia ixx="0.02314" ixy="0" ixz="0" iyy="0.00784" iyz="0" izz="0.02314" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage.glb" />
      </geometry>
      <material name="carriage_orange" />
    </visual>
    <collision>
      <geometry>
        <box size="0.14 0.31 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.13 -0.028" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.055 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.13 -0.028" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.055 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.075 0.11" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0 0.145 0" rpy="0 0 0" />
      <mass value="1.7" />
      <inertia ixx="0.0121408" ixy="0" ixz="0" iyy="0.00113333" iyz="0" izz="0.0128208" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="arm_blue" />
    </visual>
    <collision>
      <origin xyz="0 0.025 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.05 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.12 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.24 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.24 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.05 0.03" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0 0.13 0" rpy="0 0 0" />
      <mass value="1.05" />
      <inertia ixx="0.006055" ixy="0" ixz="0" iyy="0.001015" iyz="0" izz="0.00679" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="tool_black" />
    </visual>
    <collision>
      <origin xyz="0 0.02 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.04 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.09 0" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.18 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.22 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.065 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="gantry_slide" type="prismatic">
    <origin xyz="0 0 0.06" rpy="0 0 0" />
    <parent link="gantry" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="0.6" lower="-0.19" upper="0.19" />
  </joint>
  <joint name="shoulder_yaw" type="revolute">
    <origin xyz="0 0 0.085" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="upper_arm" />
    <axis xyz="0 0 1" />
    <limit effort="35" velocity="2" lower="-1.15" upper="1.15" />
  </joint>
  <joint name="elbow_yaw" type="revolute">
    <origin xyz="0 0.24 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="2.5" lower="-1.55" upper="1.3" />
  </joint>
</robot>