<robot name="tilting_cradle">
  <material name="frame_blue">
    <color rgba="0.18 0.33 0.56 1" />
  </material>
  <material name="dark_steel">
    <color rgba="0.24 0.24 0.26 1" />
  </material>
  <material name="plate_gray">
    <color rgba="0.68 0.7 0.73 1" />
  </material>
  <link name="base_plate">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <mass value="5.5" />
      <inertia ixx="0.0150333" ixy="0" ixz="0" iyy="0.0889167" iyz="0" izz="0.103583" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_plate.glb" />
      </geometry>
      <material name="frame_blue" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.44 0.18 0.02" />
      </geometry>
    </collision>
  </link>
  <link name="support_frame">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <mass value="4" />
      <inertia ixx="0.0112333" ixy="0" ixz="0" iyy="0.0618667" iyz="0" izz="0.0560333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/support_frame.glb" />
      </geometry>
      <material name="frame_blue" />
    </visual>
    <collision>
      <origin xyz="-0.17 0 0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.08 0.11" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.17 0 0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.08 0.11" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.018" rpy="0 0 0" />
      <geometry>
        <box size="0.28 0.05 0.036" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.028 0.14" rpy="0 0 0" />
      <geometry>
        <box size="0.32 0.016 0.018" />
      </geometry>
    </collision>
  </link>
  <link name="support_shaft">
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <mass value="0.9" />
      <inertia ixx="0.0087024" ixy="0" ixz="0" iyy="0.0087024" iyz="0" izz="6.48e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/support_shaft.glb" />
      </geometry>
      <material name="dark_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.012" length="0.34" />
      </geometry>
    </collision>
  </link>
  <link name="cradle_yoke">
    <inertial>
      <origin xyz="0 0 -0.035" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00241333" ixy="0" ixz="0" iyy="0.0115333" iyz="0" izz="0.0117867" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/cradle_yoke.glb" />
      </geometry>
      <material name="dark_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.018" length="0.27" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.11 0 -0.0375" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.1 0.075" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.11 0 -0.0375" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.1 0.075" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.066" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.03 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="equipment_plate">
    <inertial>
      <origin xyz="0 0 -0.005" rpy="0 0 0" />
      <mass value="1.8" />
      <inertia ixx="0.004875" ixy="0" ixz="0" iyy="0.010155" iyz="0" izz="0.015" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/equipment_plate.glb" />
      </geometry>
      <material name="plate_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.26 0.18 0.01" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_supports" type="fixed">
    <origin xyz="0 0 0.02" rpy="0 0 0" />
    <parent link="base_plate" />
    <child link="support_frame" />
  </joint>
  <joint name="supports_to_shaft" type="fixed">
    <origin xyz="0 0 0.14" rpy="0 0 0" />
    <parent link="support_frame" />
    <child link="support_shaft" />
  </joint>
  <joint name="shaft_to_cradle" type="revolute">
    <parent link="support_shaft" />
    <child link="cradle_yoke" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="1.5" lower="-0.7" upper="0.8" />
  </joint>
  <joint name="cradle_to_plate" type="fixed">
    <origin xyz="0 0 -0.07" rpy="0 0 0" />
    <parent link="cradle_yoke" />
    <child link="equipment_plate" />
  </joint>
</robot>