<robot name="fold_out_boom">
  <material name="boom_orange">
    <color rgba="0.92 0.58 0.16 1" />
    </material>
  <material name="boom_dark">
    <color rgba="0.24 0.27 0.31 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 -0.035" rpy="0 0 0" />
      <mass value="6" />
      <inertia ixx="0.00905" ixy="0" ixz="0" iyy="0.01385" iyz="0" izz="0.0148" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base.obj" />
        </geometry>
      <material name="boom_dark" />
      </visual>
    </link>
  <link name="boom_1">
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.0165733" ixy="0" ixz="0" iyy="0.0166366" iyz="0" izz="0.00020997" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/boom_1.obj" />
        </geometry>
      <material name="boom_orange" />
      </visual>
    </link>
  <link name="boom_2">
    <inertial>
      <origin xyz="0 0 0.13" rpy="0 0 0" />
      <mass value="1.7" />
      <inertia ixx="0.00963333" ixy="0" ixz="0" iyy="0.00968225" iyz="0" izz="0.000162249" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/boom_2.obj" />
        </geometry>
      <material name="boom_orange" />
      </visual>
    </link>
  <link name="boom_3">
    <inertial>
      <origin xyz="0 0 0.11" rpy="0 0 0" />
      <mass value="1.3" />
      <inertia ixx="0.00528667" ixy="0" ixz="0" iyy="0.00532407" iyz="0" izz="0.000124073" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/boom_3.obj" />
        </geometry>
      <material name="boom_orange" />
      </visual>
    </link>
  <link name="boom_4">
    <inertial>
      <origin xyz="0 0 0.09" rpy="0 0 0" />
      <mass value="0.9" />
      <inertia ixx="0.00246" ixy="0" ixz="0" iyy="0.0024859" iyz="0" izz="8.58968e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/boom_4.obj" />
        </geometry>
      <material name="boom_orange" />
      </visual>
    </link>
  <joint name="base_to_boom_1" type="revolute">
    <parent link="base" />
    <child link="boom_1" />
    <axis xyz="0 1 0" />
    <limit effort="18" velocity="1.2" lower="0" upper="1.2" />
    </joint>
  <joint name="boom_1_to_boom_2" type="revolute">
    <origin xyz="0 0 0.3" rpy="0 0 0" />
    <parent link="boom_1" />
    <child link="boom_2" />
    <axis xyz="0 1 0" />
    <limit effort="14" velocity="1.5" lower="0" upper="1.25" />
    </joint>
  <joint name="boom_2_to_boom_3" type="revolute">
    <origin xyz="0 0 0.26" rpy="0 0 0" />
    <parent link="boom_2" />
    <child link="boom_3" />
    <axis xyz="0 1 0" />
    <limit effort="11" velocity="1.7" lower="0" upper="1.3" />
    </joint>
  <joint name="boom_3_to_boom_4" type="revolute">
    <origin xyz="0 0 0.22" rpy="0 0 0" />
    <parent link="boom_3" />
    <child link="boom_4" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2" lower="0" upper="1.35" />
    </joint>
  </robot>
