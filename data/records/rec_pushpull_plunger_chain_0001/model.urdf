    <child link="stage2" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.2" lower="0" upper="0.025" />
  </joint>
  <joint name="stage2_to_stage3" type="prismatic">
    <origin xyz="0.095 0 0" rpy="0 0 0" />
    <parent link="stage2" />
    <child link="stage3" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.24" lower="0" upper="0.022" />
  </joint>
</robot>