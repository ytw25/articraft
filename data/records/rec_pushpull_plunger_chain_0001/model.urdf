        <box size="0.074 0.005 0.026" />
      </geometry>
    </collision>
    <collision name="guide_right">
      <origin xyz="0.025 -0.0155 0" rpy="0 0 0" />
      <geometry>
        <box size="0.074 0.005 0.026" />
      </geometry>
    </collision>
  </link>
  <link name="stage1">
    <inertial>
      <origin xyz="0.03 0 0" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.000165" ixy="0" ixz="0" iyy="0.00288979" iyz="0" izz="0.00288979" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stage1.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <collision name="rod">
      <origin xyz="0.001 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.112 0.021 0.021" />
      </geometry>
    </collision>
    <collision name="guide_top">
      <origin xyz="0.0825 0 0.0115" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.028 0.005" />
      </geometry>
    </collision>
    <collision name="guide_bottom">
      <origin xyz="0.0825 0 -0.0115" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.028 0.005" />
      </geometry>
    </collision>
    <collision name="guide_left">
      <origin xyz="0.0825 0.0115 0" rpy="0 0 0" />
