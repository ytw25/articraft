      </geometry>
    </collision>
  </link>
  <joint name="frame_to_stage1" type="prismatic">
    <origin xyz="0.062 0 0" rpy="0 0 0" />
    <parent link="frame" />
    <child link="stage1" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="0.18" lower="0" upper="0.03" />
  </joint>
  <joint name="stage1_to_stage2" type="prismatic">
    <origin xyz="0.11 0 0" rpy="0 0 0" />
