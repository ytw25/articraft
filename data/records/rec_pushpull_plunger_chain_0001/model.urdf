      <origin xyz="0.026 0 0" rpy="0 0 0" />
      <mass value="0.55" />
      <inertia ixx="4.43667e-05" ixy="0" ixz="0" iyy="0.000985829" iyz="0" izz="0.000985829" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stage2.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <collision name="rod">
      <geometry>
        <box size="0.09 0.014 0.014" />
      </geometry>
    </collision>
    <collision name="guide_top">
      <origin xyz="0.07 0 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.02 0.004" />
      </geometry>
    </collision>
    <collision name="guide_bottom">
      <origin xyz="0.07 0 -0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.02 0.004" />
      </geometry>
    </collision>
    <collision name="guide_left">
      <origin xyz="0.07 0.008 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.004 0.012" />
      </geometry>
    </collision>
    <collision name="guide_right">
      <origin xyz="0.07 -0.008 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.004 0.012" />
