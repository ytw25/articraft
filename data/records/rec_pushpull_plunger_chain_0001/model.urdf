    </collision>
  </link>
  <link name="stage3">
    <inertial>
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <mass value="0.18" />
      <inertia ixx="7.68e-06" ixy="0" ixz="0" iyy="0.000202215" iyz="0" izz="0.000202215" />
    </inertial>
