<robot name="push_pull_plunger_chain">
  <material name="housing">
    <color rgba="0.18 0.2 0.22 1" />
  </material>
  <material name="steel">
    <color rgba="0.7 0.72 0.75 1" />
  </material>
  <material name="tool_steel">
    <color rgba="0.48 0.5 0.54 1" />
  </material>
  <link name="frame">
    <inertial>
      <origin xyz="-0.055 0 -0.004" rpy="0 0 0" />
      <mass value="4.2" />
      <inertia ixx="0.00707" ixy="0" ixz="0" iyy="0.022995" iyz="0" izz="0.024395" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/frame.glb" />
      </geometry>
      <material name="housing" />
    </visual>
    <collision name="rear_body">
