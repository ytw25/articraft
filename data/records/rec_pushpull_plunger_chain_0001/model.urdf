    </collision>
    <collision name="rear_block">
      <origin xyz="-0.135 0 0.014" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.11 0.075" />
      </geometry>
    </collision>
    <collision name="base_foot">
