  <joint name="slewing_joint" type="continuous">
    <origin xyz="0 0 0.2" rpy="0 0 0" />
    <parent link="chassis" />
    <child link="slewing_platform" />
    <axis xyz="0 0 1" />
    <limit effort="1000" velocity="1" />
    </joint>
  <joint name="boom_pitch" type="revolute">
    <origin xyz="0.25 0 0.4" rpy="0 0 0" />
    <parent link="slewing_platform" />
    <child link="boom_base" />
    <axis xyz="0 -1 0" />
    <limit effort="5000" velocity="0.5" lower="0" upper="1.4" />
    </joint>
  <joint name="boom_extension" type="prismatic">
    <origin xyz="0.1 0 0" rpy="0 0 0" />
    <parent link="boom_base" />
    <child link="boom_ext" />
    <axis xyz="1 0 0" />
    <limit effort="2000" velocity="0.5" lower="0" upper="0.7" />
    </joint>
  <joint name="hoist" type="prismatic">
    <origin xyz="0.96 0 -0.05" rpy="0 0 0" />
