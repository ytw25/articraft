<robot name="collapsible_service_arm">
  <material name="graphite">
    <color rgba="0.2 0.22 0.25 1" />
  </material>
  <material name="aluminum">
    <color rgba="0.73 0.74 0.76 1" />
  </material>
  <material name="service_orange">
    <color rgba="0.9 0.43 0.12 1" />
  </material>
  <link name="base_mount">
    <inertial>
      <origin xyz="-0.025 0 0" rpy="0 0 0" />
      <mass value="0.72" />
      <inertia ixx="0.000192" ixy="0" ixz="0" iyy="0.000534" iyz="0" izz="0.00071832" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_mount.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <collision>
      <origin xyz="-0.025 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.094 0.056 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="arm_1">
    <inertial>
      <origin xyz="0.065 0 0" rpy="0 0 0" />
      <mass value="0.42" />
      <inertia ixx="6.398e-05" ixy="0" ixz="0" iyy="0.00103768" iyz="0" izz="0.00109718" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/arm_1.glb" />
      </geometry>
      <material name="aluminum" />
    </visual>
    <collision>
      <origin xyz="0.065 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.172 0.042 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="arm_2">
    <inertial>
      <origin xyz="0.055 0 0" rpy="0 0 0" />
      <mass value="0.34" />
      <inertia ixx="4.71467e-05" ixy="0" ixz="0" iyy="0.000639313" iyz="0" izz="0.000682833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/arm_2.glb" />
      </geometry>
      <material name="aluminum" />
    </visual>
    <collision>
      <origin xyz="0.055 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.04 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="service_plate">
    <inertial>
      <origin xyz="0.036 0 0" rpy="0 0 0" />
      <mass value="0.28" />
      <inertia ixx="6.45867e-05" ixy="0" ixz="0" iyy="0.000273653" iyz="0" izz="0.000335253" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/service_plate.glb" />
      </geometry>
      <material name="service_orange" />
    </visual>
    <collision>
      <origin xyz="0.036 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.108 0.052 0.008" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_shoulder" type="revolute">
    <origin xyz="0 0 0.008" rpy="0 0 0" />
    <parent link="base_mount" />
    <child link="arm_1" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" lower="-2.4" upper="2.4" />
  </joint>
  <joint name="shoulder_to_elbow" type="revolute">
    <origin xyz="0.13 0 0.01" rpy="0 0 0" />
    <parent link="arm_1" />
    <child link="arm_2" />
    <axis xyz="0 0 1" />
    <limit effort="6" velocity="2.8" lower="-2.7" upper="2.7" />
  </joint>
  <joint name="elbow_to_service" type="revolute">
    <origin xyz="0.11 0 0.01" rpy="0 0 0" />
    <parent link="arm_2" />
    <child link="service_plate" />
    <axis xyz="0 0 1" />
    <limit effort="4" velocity="3" lower="-2.4" upper="2.4" />
  </joint>
</robot>