  <link name="wire_frame">
    <inertial>
      <origin xyz="0.026 0.001 0.037" rpy="0 0 0" />
      <mass value="0.06" />
      <inertia ixx="3.25e-05" ixy="0" ixz="0" iyy="4.09e-05" iyz="0" izz="1.864e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/left_outer_arm.obj" />
