      <inertia ixx="1.5e-05" ixy="0" ixz="0" iyy="2.08333e-05" iyz="0" izz="2.08333e-05" />
      </inertial>
    <visual>
      <origin xyz="0.02 -0.009 0.008" rpy="0 0 0" />
      <geometry>
