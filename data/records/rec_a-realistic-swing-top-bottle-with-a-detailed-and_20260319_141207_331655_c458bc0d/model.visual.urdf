    </link>
  <joint name="bottle_body_to_liquid" type="fixed">
    <origin xyz="0.03 0 0.15" rpy="0 0 0" />
    <parent link="bottle_body" />
    <child link="liquid" />
    </joint>
  <joint name="bottle_to_wire_frame" type="revolute">
    <origin xyz="-0.026 0 0.206" rpy="0 0 0" />
    <parent link="bottle_body" />
    <child link="wire_frame" />
    <axis xyz="1 0 0" />
    <limit effort="4" velocity="3" lower="0" upper="1.2" />
    </joint>
  <joint name="wire_frame_to_stopper" type="revolute">
    <origin xyz="0.006 0.012 0.07" rpy="0 0 0" />
    <parent link="wire_frame" />
    <child link="stopper" />
    <axis xyz="1 0 0" />
    <limit effort="2" velocity="3" lower="-1.1" upper="0.1" />
    </joint>
  </robot>
