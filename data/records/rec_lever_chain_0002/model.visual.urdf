<robot name="serial_lever_chain">
  <material name="frame_paint">
    <color rgba="0.24 0.27 0.31 1" />
    </material>
  <material name="lever_steel">
    <color rgba="0.74 0.76 0.79 1" />
    </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="-0.01 0 -0.03" rpy="0 0 0" />
      <mass value="2.8" />
      <inertia ixx="0.00382667" ixy="0" ixz="0" iyy="0.00830667" iyz="0" izz="0.00746667" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_frame.obj" />
        </geometry>
      <material name="frame_paint" />
      </visual>
    </link>
  <link name="link1">
    <inertial>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="2.89e-05" ixy="0" ixz="0" iyy="0.0006625" iyz="0" izz="0.0006464" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/link1.obj" />
        </geometry>
      <material name="lever_steel" />
      </visual>
    </link>
  <link name="link2">
    <inertial>
      <origin xyz="0.08 0 0" rpy="0 0 0" />
      <mass value="0.27" />
      <inertia ixx="2.601e-05" ixy="0" ixz="0" iyy="0.00046125" iyz="0" izz="0.00044676" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/link2.obj" />
        </geometry>
      <material name="lever_steel" />
      </visual>
    </link>
  <link name="link3">
    <inertial>
      <origin xyz="0.07 0 0" rpy="0 0 0" />
      <mass value="0.24" />
      <inertia ixx="2.312e-05" ixy="0" ixz="0" iyy="0.000306" iyz="0" izz="0.00029312" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/link3.obj" />
        </geometry>
      <material name="lever_steel" />
      </visual>
    </link>
  <link name="link4">
    <inertial>
      <origin xyz="0.06 0 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="1.92667e-05" ixy="0" ixz="0" iyy="0.000181667" iyz="0" izz="0.000170933" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/link4.obj" />
        </geometry>
      <material name="lever_steel" />
      </visual>
    </link>
  <joint name="base_to_link1" type="revolute">
    <parent link="base_frame" />
    <child link="link1" />
    <axis xyz="0 1 0" />
    <limit effort="14" velocity="1.6" lower="-0.6" upper="0.35" />
    </joint>
  <joint name="link1_to_link2" type="revolute">
    <origin xyz="0.18 0 0" rpy="0 0 0" />
    <parent link="link1" />
    <child link="link2" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="1.8" lower="-0.65" upper="0.55" />
    </joint>
  <joint name="link2_to_link3" type="revolute">
    <origin xyz="0.16 0 0" rpy="0 0 0" />
    <parent link="link2" />
    <child link="link3" />
    <axis xyz="0 1 0" />
    <limit effort="10" velocity="1.8" lower="-0.65" upper="0.55" />
    </joint>
  <joint name="link3_to_link4" type="revolute">
    <origin xyz="0.14 0 0" rpy="0 0 0" />
    <parent link="link3" />
    <child link="link4" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2" lower="-0.65" upper="0.55" />
    </joint>
  </robot>
