<robot name="orthogonal_xz_stage">
  <material name="graphite">
    <color rgba="0.22 0.24 0.27 1" />
  </material>
  <material name="steel">
    <color rgba="0.7 0.72 0.75 1" />
  </material>
  <material name="anodized">
    <color rgba="0.56 0.6 0.64 1" />
  </material>
  <material name="light_panel">
    <color rgba="0.82 0.84 0.86 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <mass value="12" />
      <inertia ixx="0.033424" ixy="0" ixz="0" iyy="0.271424" iyz="0" izz="0.3028" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_structure.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/base_rails.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.52 0.18 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.055 0.026" rpy="0 0 0" />
      <geometry>
        <box size="0.4 0.018 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0.026" rpy="0 0 0" />
      <geometry>
        <box size="0.4 0.018 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="x_stage">
    <inertial>
      <origin xyz="0 -0.055 0.145" rpy="0 0 0" />
      <mass value="6.5" />
      <inertia ixx="0.0577417" ixy="0" ixz="0" iyy="0.0547083" iyz="0" izz="0.0213417" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/x_stage_body.glb" />
      </geometry>
      <material name="anodized" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/x_stage_rail.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.03 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.11 0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.03 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.13 0.15 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.07 0.162" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.018 0.26" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.049 0.155" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.01 0.2" />
      </geometry>
    </collision>
  </link>
  <link name="z_stage">
    <inertial>
      <origin xyz="0 0.032 0" rpy="0 0 0" />
      <mass value="2.8" />
      <inertia ixx="0.00489907" ixy="0" ixz="0" iyy="0.00676667" iyz="0" izz="0.00377907" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/z_stage.glb" />
      </geometry>
      <material name="light_panel" />
    </visual>
    <collision>
      <origin xyz="0 0.016 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.032 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.051 0" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.012 0.13" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.032 -0.046" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.028 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_x_stage" type="prismatic">
    <origin xyz="0 0.055 0.032" rpy="0 0 0" />
    <parent link="base" />
    <child link="x_stage" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="0.4" lower="-0.13" upper="0.13" />
  </joint>
  <joint name="x_stage_to_z_stage" type="prismatic">
    <origin xyz="0 -0.044 0.105" rpy="0 0 0" />
    <parent link="x_stage" />
    <child link="z_stage" />
    <axis xyz="0 0 1" />
    <limit effort="140" velocity="0.25" lower="0" upper="0.1" />
  </joint>
</robot>