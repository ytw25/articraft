<robot name="linear_dual_rotary_module">
  <material name="base_steel">
    <color rgba="0.53 0.56 0.6 1" />
  </material>
  <material name="carriage_dark">
    <color rgba="0.2 0.22 0.26 1" />
  </material>
  <material name="joint_blue">
    <color rgba="0.24 0.39 0.65 1" />
  </material>
  <material name="arm_silver">
    <color rgba="0.72 0.74 0.77 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <mass value="4.5" />
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.04395" iyz="0" izz="0.04875" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/module_base.glb" />
      </geometry>
      <material name="base_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.12 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.021" rpy="0 0 0" />
      <geometry>
        <box size="0.29 0.058 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.146 0 0.026" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.06 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.146 0 0.026" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.06 0.028" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0.01 0 0.035" rpy="0 0 0" />
      <mass value="1.7" />
      <inertia ixx="0.00184167" ixy="0" ixz="0" iyy="0.00240833" iyz="0" izz="0.00286167" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/module_carriage.glb" />
      </geometry>
      <material name="carriage_dark" />
    </visual>
    <collision>
      <origin xyz="0.002 0 0.018" rpy="0 0 0" />
      <geometry>
        <box size="0.108 0.09 0.034" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.036 0 0.05" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.058 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.052 0 0.063" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.025" length="0.006" />
      </geometry>
    </collision>
  </link>
  <link name="shoulder_link">
    <inertial>
      <origin xyz="0.06 0 0.025" rpy="0 0 0" />
      <mass value="1.15" />
      <inertia ixx="0.000479167" ixy="0" ixz="0" iyy="0.00173698" iyz="0" izz="0.00173698" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/module_shoulder.glb" />
      </geometry>
      <material name="joint_blue" />
    </visual>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.021" length="0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.055 0 0.026" rpy="0 0 0" />
      <geometry>
        <box size="0.108 0.036 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.112 0.018 0.028" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.008 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.112 -0.018 0.028" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.008 0.04" />
      </geometry>
    </collision>
  </link>
  <link name="forearm_link">
    <inertial>
      <origin xyz="0.065 0 0" rpy="0 0 0" />
      <mass value="0.85" />
      <inertia ixx="0.000256771" ixy="0" ixz="0" iyy="0.00140427" iyz="0" izz="0.00143438" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/module_forearm.glb" />
      </geometry>
      <material name="arm_silver" />
    </visual>
    <collision>
      <geometry>
        <box size="0.024 0.022 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.06 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.098 0.024 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.113 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.045 0.03" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_carriage" type="prismatic">
    <origin xyz="-0.08 0 0.03" rpy="0 0 0" />
    <parent link="base" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="250" velocity="0.25" lower="0" upper="0.14" />
  </joint>
  <joint name="carriage_to_shoulder" type="revolute">
    <origin xyz="0.052 0 0.068" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="shoulder_link" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="1.2" lower="-1.2" upper="1.2" />
  </joint>
  <joint name="shoulder_to_forearm" type="revolute">
    <origin xyz="0.112 0 0.028" rpy="0 0 0" />
    <parent link="shoulder_link" />
    <child link="forearm_link" />
    <axis xyz="0 -1 0" />
    <limit effort="25" velocity="1.5" lower="-0.45" upper="1.1" />
  </joint>
</robot>