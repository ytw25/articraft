  <joint name="base_to_left_upper" type="revolute">
    <origin xyz="-0.15 0 0.215" rpy="0 0 0" />
    <parent link="base" />
    <child link="left_upper_arm" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="1.4" lower="0" upper="1.2" />
  </joint>
  <joint name="left_upper_to_forearm" type="revolute">
