  <link name="right_forearm">
    <inertial>
      <origin xyz="0.08 0 0" rpy="0 0 0" />
      <mass value="0.4" />
      <inertia ixx="0.000120833" ixy="0" ixz="0" iyy="0.000920833" iyz="0" izz="0.000906667" />
