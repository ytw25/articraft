  <material name="right_branch">
    <color rgba="0.18 0.47 0.84 1" />
  </material>
  <material name="link_dark">
    <color rgba="0.35 0.37 0.4 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.12" rpy="0 0 0" />
      <mass value="3.6" />
      <inertia ixx="0.02316" ixy="0" ixz="0" iyy="0.0408" iyz="0" izz="0.0294" />
    </inertial>
