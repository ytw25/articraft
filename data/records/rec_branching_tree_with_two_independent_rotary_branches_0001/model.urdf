    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/left_upper_arm.glb" />
      </geometry>
      <material name="left_branch" />
    </visual>
    <collision>
      <origin xyz="-0.022 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.048 0.052" />
