<robot name="pan_turntable_sensor_mount">
  <material name="powder_black">
    <color rgba="0.16 0.17 0.19 1" />
  </material>
  <material name="machined_aluminum">
    <color rgba="0.74 0.76 0.79 1" />
  </material>
  <material name="pedestal_gray">
    <color rgba="0.58 0.6 0.64 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
      <mass value="1.35" />
      <inertia ixx="0.00382219" ixy="0" ixz="0" iyy="0.00382219" iyz="0" izz="0.00744188" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/turntable_base.glb" />
      </geometry>
      <material name="powder_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.003" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.11" length="0.006" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.095" length="0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.026" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.033" length="0.008" />
      </geometry>
    </collision>
  </link>
  <link name="turntable_plate">
    <inertial>
      <origin xyz="0 0 0.0055" rpy="0 0 0" />
      <mass value="0.7" />
      <inertia ixx="0.00142456" ixy="0" ixz="0" iyy="0.00142456" iyz="0" izz="0.002835" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/turntable_plate.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <collision>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.09" length="0.008" />
      </geometry>
    </collision>
  </link>
  <link name="payload_pedestal">
    <inertial>
      <origin xyz="0 0 0.0445" rpy="0 0 0" />
      <mass value="0.58" />
      <inertia ixx="0.000529057" ixy="0" ixz="0" iyy="0.000654723" iyz="0" izz="0.000418083" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/payload_pedestal.glb" />
      </geometry>
      <material name="pedestal_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.003" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.05 0.006" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.043" rpy="0 0 0" />
      <geometry>
        <box size="0.038 0.03 0.074" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.083" rpy="0 0 0" />
      <geometry>
        <box size="0.075 0.055 0.006" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_turntable" type="revolute">
    <origin xyz="0 0 0.03" rpy="0 0 0" />
    <parent link="base" />
    <child link="turntable_plate" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="2.5" lower="-2.967" upper="2.967" />
  </joint>
  <joint name="turntable_to_pedestal" type="fixed">
    <origin xyz="0.035 0 0.008" rpy="0 0 0" />
    <parent link="turntable_plate" />
    <child link="payload_pedestal" />
  </joint>
</robot>