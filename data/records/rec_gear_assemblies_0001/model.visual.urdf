        <mesh filename="assets/meshes/output_gear.obj" />
        </geometry>
      <material name="machined_steel" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/output_flange.obj" />
        </geometry>
      <material name="dark_oxide" />
      </visual>
    </link>
  <joint name="bed_to_input_support" type="fixed">
    <origin xyz="-0.078 0 0.02" rpy="0 0 0" />
    <parent link="bed" />
    <child link="input_support" />
    </joint>
  <joint name="bed_to_compound_support" type="fixed">
    <origin xyz="0 0 0.02" rpy="0 0 0" />
    <parent link="bed" />
    <child link="compound_support" />
    </joint>
  <joint name="bed_to_output_support" type="fixed">
    <origin xyz="0.078 0 0.02" rpy="0 0 0" />
    <parent link="bed" />
    <child link="output_support" />
    </joint>
  <joint name="input_spin" type="continuous">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="input_support" />
    <child link="input_gear" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="25" />
    </joint>
  <joint name="compound_spin" type="continuous">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="compound_support" />
    <child link="compound_cluster" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="25" />
    </joint>
  <joint name="output_spin" type="continuous">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="output_support" />
    <child link="output_gear" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="25" />
    </joint>
  </robot>
