<robot name="industrial_compound_gear_train">
  <material name="painted_steel">
    <color rgba="0.24 0.28 0.32 1" />
    </material>
  <material name="machined_steel">
    <color rgba="0.66 0.68 0.71 1" />
    </material>
  <material name="dark_oxide">
    <color rgba="0.14 0.15 0.17 1" />
    </material>
  <material name="bronze">
    <color rgba="0.73 0.55 0.24 1" />
    </material>
  <material name="signal_red">
    <color rgba="0.68 0.15 0.13 1" />
    </material>
  <link name="bed">
    <inertial>
      <origin xyz="0 0 0.013" rpy="0 0 0" />
      <mass value="8" />
      <inertia ixx="0.0150533" ixy="0" ixz="0" iyy="0.0512347" iyz="0" izz="0.0653867" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gear_train_bed.obj" />
