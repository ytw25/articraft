  <link name="output_support">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <mass value="1" />
      <inertia ixx="0.000309667" ixy="0" ixz="0" iyy="0.000358667" iyz="0" izz="0.000401667" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/output_support.obj" />
