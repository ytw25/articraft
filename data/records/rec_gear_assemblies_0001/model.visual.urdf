  <link name="input_gear">
    <inertial>
      <origin xyz="0 0 0.044" rpy="0 0 0" />
      <mass value="1.05" />
      <inertia ixx="0.00135415" ixy="0" ixz="0" iyy="0.00135415" iyz="0" izz="0.0009583" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/input_gear.obj" />
        </geometry>
      <material name="machined_steel" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/input_handwheel.obj" />
        </geometry>
      <material name="signal_red" />
      </visual>
    </link>
  <link name="compound_cluster">
    <inertial>
      <origin xyz="0 0 0.031" rpy="0 0 0" />
      <mass value="1.55" />
      <inertia ixx="0.00221392" ixy="0" ixz="0" iyy="0.00221392" iyz="0" izz="0.0030132" />
      </inertial>
