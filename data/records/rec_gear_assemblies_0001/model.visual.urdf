    <visual>
      <origin xyz="-0.016 0 0.0095" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0038" length="0.003" />
        </geometry>
      <material name="dark_oxide" />
      </visual>
    <visual>
      <origin xyz="0.016 0 0.0095" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0038" length="0.003" />
        </geometry>
      <material name="dark_oxide" />
