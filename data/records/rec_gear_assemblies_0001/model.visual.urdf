      <mass value="1.15" />
      <inertia ixx="0.000374133" ixy="0" ixz="0" iyy="0.000475717" iyz="0" izz="0.000543183" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/compound_support.obj" />
