  <link name="output_gear">
    <inertial>
      <origin xyz="0 0 0.038" rpy="0 0 0" />
      <mass value="1.45" />
      <inertia ixx="0.00256167" ixy="0" ixz="0" iyy="0.00256167" iyz="0" izz="0.00325187" />
