  <joint name="base_yaw" type="revolute">
    <origin xyz="0 0 0.127" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="turret" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="1.6" lower="-2.9" upper="2.9" />
    </joint>
  <joint name="shoulder_pitch" type="revolute">
    <origin xyz="0 0 0.214" rpy="0 0 0" />
    <parent link="turret" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="90" velocity="1.8" lower="-0.75" upper="1.55" />
    </joint>
  <joint name="elbow_pitch" type="revolute">
    <origin xyz="0.34 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="70" velocity="2" lower="-0.25" upper="2.35" />
    </joint>
  <joint name="wrist_pitch" type="revolute">
    <origin xyz="0.3 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="2.6" lower="-1.45" upper="1.55" />
    </joint>
  <joint name="wrist_roll" type="continuous">
    <origin xyz="0.094 0 0" rpy="0 0 0" />
    <parent link="wrist" />
    <child link="tool_head" />
    <axis xyz="1 0 0" />
    <limit effort="22" velocity="3.4" />
    </joint>
