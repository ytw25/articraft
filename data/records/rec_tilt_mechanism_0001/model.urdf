<robot name="motorized_tilt_cradle">
  <material name="tower_dark">
    <color rgba="0.16 0.18 0.21 1" />
  </material>
  <material name="plate_light">
    <color rgba="0.74 0.77 0.8 1" />
  </material>
  <link name="stand">
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
      <mass value="3.8" />
      <inertia ixx="0.00912" ixy="0" ixz="0" iyy="0.01482" iyz="0" izz="0.01482" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stand.glb" />
      </geometry>
      <material name="tower_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.12 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.006 0 0.041" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.03 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.032 0.096" rpy="0 0 0" />
      <geometry>
        <box size="0.034 0.012 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.032 0.096" rpy="0 0 0" />
      <geometry>
        <box size="0.034 0.012 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.018 0.115" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.008 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.018 0.115" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.008 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="cradle">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.000676133" ixy="0" ixz="0" iyy="0.00194333" iyz="0" izz="0.00232613" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/cradle.glb" />
      </geometry>
      <material name="plate_light" />
    </visual>
    <collision>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.07 0.008" />
      </geometry>
    </collision>
  </link>
  <joint name="tilt_joint" type="revolute">
    <origin xyz="0 0 0.115" rpy="0 0 0" />
    <parent link="stand" />
    <child link="cradle" />
    <axis xyz="0 1 0" />
    <limit effort="18" velocity="1.5" lower="-0.55" upper="0.9" />
  </joint>
</robot>