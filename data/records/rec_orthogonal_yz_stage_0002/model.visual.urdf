<robot name="orthogonal_yz_stage">
  <material name="frame_dark">
    <color rgba="0.22 0.23 0.25 1" />
    </material>
  <material name="rail_steel">
    <color rgba="0.66 0.68 0.71 1" />
    </material>
  <material name="carriage_aluminum">
    <color rgba="0.78 0.79 0.81 1" />
    </material>
  <material name="guide_block">
    <color rgba="0.32 0.34 0.37 1" />
    </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="0 0 0.21" rpy="0 0 0" />
      <mass value="12" />
      <inertia ixx="0.3208" ixy="0" ixz="0" iyy="0.18" iyz="0" izz="0.148" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_frame.obj" />
        </geometry>
      <material name="frame_dark" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_rails.obj" />
        </geometry>
      <material name="rail_steel" />
      </visual>
    </link>
  <link name="y_stage">
    <inertial>
      <origin xyz="-0.006 0 0.17" rpy="0 0 0" />
      <mass value="3.5" />
      <inertia ixx="0.0303333" ixy="0" ixz="0" iyy="0.0233333" iyz="0" izz="0.00793333" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_stage_frame.obj" />
        </geometry>
      <material name="carriage_aluminum" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_stage_guides.obj" />
        </geometry>
      <material name="guide_block" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/y_stage_rails.obj" />
        </geometry>
      <material name="rail_steel" />
      </visual>
    </link>
  <link name="z_stage">
    <inertial>
      <origin xyz="0.024 0.05 -0.02" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00433333" ixy="0" ixz="0" iyy="0.00166667" iyz="0" izz="0.00333333" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/z_stage_carriage.obj" />
        </geometry>
      <material name="carriage_aluminum" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/z_stage_guides.obj" />
        </geometry>
      <material name="guide_block" />
      </visual>
    </link>
  <joint name="base_to_y_stage" type="prismatic">
    <origin xyz="0.034 0 0.13" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="y_stage" />
    <axis xyz="0 1 0" />
    <limit effort="500" velocity="0.3" lower="-0.06" upper="0.06" />
    </joint>
  <joint name="y_stage_to_z_stage" type="prismatic">
    <origin xyz="0.016 -0.05 0.08" rpy="0 0 0" />
    <parent link="y_stage" />
    <child link="z_stage" />
    <axis xyz="0 0 1" />
    <limit effort="350" velocity="0.25" lower="0" upper="0.12" />
    </joint>
  </robot>
