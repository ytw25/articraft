<robot name="compact_serial_elbow_arm">
  <material name="base_gray">
    <color rgba="0.36 0.39 0.43 1" />
  </material>
  <material name="arm_blue">
    <color rgba="0.18 0.34 0.72 1" />
  </material>
  <material name="dark_metal">
    <color rgba="0.18 0.19 0.22 1" />
  </material>
  <material name="tool_silver">
    <color rgba="0.72 0.74 0.78 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.0225" rpy="0 0 0" />
      <mass value="2.1" />
      <inertia ixx="0.00147437" ixy="0" ixz="0" iyy="0.00177187" iyz="0" izz="0.0025375" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/compact_elbow_arm_base.glb" />
      </geometry>
      <material name="base_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0225" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.08 0.045" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.058" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.05 0.026" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <mass value="0.68" />
      <inertia ixx="0.000191533" ixy="0" ixz="0" iyy="0.00194571" iyz="0" izz="0.00191783" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/compact_elbow_arm_upper.glb" />
      </geometry>
      <material name="arm_blue" />
    </visual>
    <collision>
      <geometry>
        <box size="0.036 0.03 0.046" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.092 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.128 0.034 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.168 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.03 0.048" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.0725 0 0" rpy="0 0 0" />
      <mass value="0.44" />
      <inertia ixx="0.000101053" ixy="0" ixz="0" iyy="0.000829583" iyz="0" izz="0.000813303" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/compact_elbow_arm_forearm.glb" />
      </geometry>
      <material name="dark_metal" />
    </visual>
    <collision>
      <geometry>
        <box size="0.032 0.026 0.042" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.077 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.108 0.03 0.036" />
      </geometry>
    </collision>
  </link>
  <link name="tool_plate">
    <inertial>
      <origin xyz="0.0135 0 0" rpy="0 0 0" />
      <mass value="0.12" />
      <inertia ixx="8.84e-05" ixy="0" ixz="0" iyy="5.917e-05" iyz="0" izz="3.805e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/compact_elbow_arm_tool_plate.glb" />
      </geometry>
      <material name="tool_silver" />
    </visual>
    <collision>
      <origin xyz="0.0075 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.015 0.028 0.036" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.018 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.058 0.074" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.066" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="2" lower="-1.05" upper="1.25" />
  </joint>
  <joint name="elbow_joint" type="revolute">
    <origin xyz="0.18 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="2.5" lower="0" upper="2.1" />
  </joint>
  <joint name="tool_plate_mount" type="fixed">
    <origin xyz="0.145 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_plate" />
  </joint>
</robot>