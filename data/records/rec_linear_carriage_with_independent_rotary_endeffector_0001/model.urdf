<robot name="slide_mounted_rotary_tool_head">
  <material name="frame_gray">
    <color rgba="0.48 0.5 0.54 1" />
  </material>
  <material name="carriage_blue">
    <color rgba="0.17 0.34 0.68 1" />
  </material>
  <material name="tool_orange">
    <color rgba="0.86 0.45 0.12 1" />
  </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <mass value="5.5" />
      <inertia ixx="0.0177833" ixy="0" ixz="0" iyy="0.0837833" iyz="0" izz="0.0957" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_frame.glb" />
      </geometry>
      <material name="frame_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.42 0.18 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.031" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.04 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0.0325" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.022 0.025" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.055 0.0325" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.022 0.025" />
      </geometry>
    </collision>
  </link>
  <link name="slide_carriage">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <mass value="1.35" />
      <inertia ixx="0.00230625" ixy="0" ixz="0" iyy="0.00153" iyz="0" izz="0.00302625" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/slide_carriage.glb" />
      </geometry>
      <material name="carriage_blue" />
    </visual>
    <collision>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.05 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.13 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.058 0 0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.085 0.07" />
      </geometry>
    </collision>
  </link>
  <link name="tool_head">
    <inertial>
      <origin xyz="0.06 0 0" rpy="0 0 0" />
      <mass value="0.95" />
      <inertia ixx="0.000894583" ixy="0" ixz="0" iyy="0.00152792" iyz="0" izz="0.00164667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_head.glb" />
      </geometry>
      <material name="tool_orange" />
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.08 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.06 0 0.044" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.03 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1275 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.024" length="0.055" />
      </geometry>
    </collision>
  </link>
  <joint name="slide_axis" type="prismatic">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="slide_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="25" velocity="0.35" lower="-0.09" upper="0.09" />
  </joint>
  <joint name="head_spin" type="revolute">
    <origin xyz="0.066 0 0.055" rpy="0 0 0" />
    <parent link="slide_carriage" />
    <child link="tool_head" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="4" lower="-1.5708" upper="1.5708" />
  </joint>
</robot>