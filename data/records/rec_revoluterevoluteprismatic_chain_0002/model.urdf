<robot name="industrial_inspection_arm">
  <material name="machine_gray">
    <color rgba="0.28 0.3 0.33 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.9 0.48 0.12 1" />
  </material>
  <material name="slide_metal">
    <color rgba="0.76 0.79 0.82 1" />
  </material>
  <material name="optic_blue">
    <color rgba="0.17 0.26 0.46 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.17" rpy="0 0 0" />
      <mass value="24" />
      <inertia ixx="0.296" ixy="0" ixz="0" iyy="0.3112" iyz="0" izz="0.1448" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="machine_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.22 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.18" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.14 0.28" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.36" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.12 0.12" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.18 0 0.01" rpy="0 0 0" />
      <mass value="7.5" />
      <inertia ixx="0.01025" ixy="0" ixz="0" iyy="0.0625" iyz="0" izz="0.06025" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.09 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.18 0 0.015" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.06 0.06" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.34 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.12 0.12" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.21 0 0.01" rpy="0 0 0" />
      <mass value="5" />
      <inertia ixx="0.00541667" ixy="0" ixz="0" iyy="0.0360417" iyz="0" izz="0.0347083" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.1 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.17 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.05 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.18 0 0.078" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.09 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.39 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.09 0.09" />
      </geometry>
    </collision>
  </link>
  <link name="tool_slide">
    <inertial>
      <origin xyz="0.16 0 0" rpy="0 0 0" />
      <mass value="1.8" />
      <inertia ixx="0.00108" ixy="0" ixz="0" iyy="0.0078" iyz="0" izz="0.0078" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_slide.glb" />
      </geometry>
      <material name="slide_metal" />
    </visual>
    <visual>
      <origin xyz="0.322 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.014" length="0.028" />
      </geometry>
      <material name="optic_blue" />
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.09 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.16 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.04 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.285 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.04 0.04" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder" type="revolute">
    <origin xyz="0 0 0.36" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="60" velocity="1.5" lower="-0.75" upper="1.05" />
  </joint>
  <joint name="elbow" type="revolute">
    <origin xyz="0.36 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1.8" lower="0" upper="1.5" />
  </joint>
  <joint name="extension" type="prismatic">
    <origin xyz="0.18 0 0.085" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_slide" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="0.3" lower="0" upper="0.16" />
  </joint>
</robot>