<robot name="compact_rotary_indexing_base">
  <material name="frame_charcoal">
    <color rgba="0.19 0.2 0.22 1" />
  </material>
  <material name="turntable_steel">
    <color rgba="0.64 0.66 0.68 1" />
  </material>
  <material name="pointer_red">
    <color rgba="0.72 0.13 0.1 1" />
  </material>
  <link name="support_frame">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="3.6" />
      <inertia ixx="0.00843" ixy="0" ixz="0" iyy="0.01527" iyz="0" izz="0.0222" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/support_frame.glb" />
      </geometry>
      <material name="frame_charcoal" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.16 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.046 0.021" rpy="0 0 0" />
      <geometry>
        <box size="0.112 0.014 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.046 0.021" rpy="0 0 0" />
      <geometry>
        <box size="0.112 0.014 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.052 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.07 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.052 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.07 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.023" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.02" length="0.022" />
      </geometry>
    </collision>
  </link>
  <link name="turntable">
    <inertial>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <mass value="1.2" />
      <inertia ixx="0.0015523" ixy="0" ixz="0" iyy="0.0015523" iyz="0" izz="0.0030246" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/turntable.glb" />
      </geometry>
      <material name="turntable_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.008" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.071" length="0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.082 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.016 0.01" />
      </geometry>
    </collision>
  </link>
  <link name="index_pointer">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="4.16667e-07" ixy="0" ixz="0" iyy="3.41667e-06" iyz="0" izz="3.53333e-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/index_pointer.glb" />
      </geometry>
      <material name="pointer_red" />
    </visual>
    <collision>
      <geometry>
        <box size="0.028 0.008 0.006" />
      </geometry>
    </collision>
  </link>
  <joint name="support_to_turntable" type="revolute">
    <origin xyz="0 0 0.036" rpy="0 0 0" />
    <parent link="support_frame" />
    <child link="turntable" />
    <axis xyz="0 0 1" />
    <limit effort="20" velocity="2.5" lower="-1.1" upper="1.1" />
  </joint>
  <joint name="turntable_to_pointer" type="fixed">
    <origin xyz="0.058 0 0.017" rpy="0 0 0" />
    <parent link="turntable" />
    <child link="index_pointer" />
  </joint>
</robot>