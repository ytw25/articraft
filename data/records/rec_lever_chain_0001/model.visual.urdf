<robot name="multi_link_lever_mechanism">
  <material name="graphite">
    <color rgba="0.22 0.24 0.28 1" />
    </material>
  <material name="blue_lever">
    <color rgba="0.22 0.46 0.76 1" />
    </material>
  <material name="amber_lever">
    <color rgba="0.85 0.55 0.16 1" />
    </material>
  <material name="green_lever">
    <color rgba="0.33 0.61 0.33 1" />
    </material>
  <material name="silver_lever">
    <color rgba="0.72 0.74 0.78 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0.03 0 0.009" rpy="0 0 0" />
      <mass value="1.5" />
      <inertia ixx="0.000943625" ixy="0" ixz="0" iyy="0.0032405" iyz="0" izz="0.00410313" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base.obj" />
        </geometry>
      <material name="graphite" />
      </visual>
    </link>
  <link name="input_lever">
    <inertial>
      <origin xyz="0.0545 0 0.00575" rpy="0 0 0" />
      <mass value="0.24" />
      <inertia ixx="1.6165e-05" ixy="0" ixz="0" iyy="0.000367145" iyz="0" izz="0.00037802" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/input_lever.obj" />
        </geometry>
      <material name="blue_lever" />
      </visual>
    </link>
  <link name="relay_arm">
    <inertial>
      <origin xyz="0.04725 0 0.00575" rpy="0 0 0" />
      <mass value="0.19" />
      <inertia ixx="1.1214e-05" ixy="0" ixz="0" iyy="0.00022443" iyz="0" izz="0.000231456" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/relay_arm.obj" />
        </geometry>
      <material name="amber_lever" />
      </visual>
    </link>
  <link name="follower_arm">
    <inertial>
      <origin xyz="0.04075 0 0.00575" rpy="0 0 0" />
      <mass value="0.16" />
      <inertia ixx="8.81667e-06" ixy="0" ixz="0" iyy="0.000147367" iyz="0" izz="0.000152657" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/follower_arm.obj" />
        </geometry>
      <material name="green_lever" />
      </visual>
    </link>
  <link name="output_lever">
    <inertial>
      <origin xyz="0.0335 0 0.002" rpy="0 0 0" />
      <mass value="0.12" />
      <inertia ixx="5e-06" ixy="0" ixz="0" iyy="7.937e-05" iyz="0" izz="8.405e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/output_lever.obj" />
        </geometry>
      <material name="silver_lever" />
      </visual>
    </link>
  <joint name="base_to_input" type="revolute">
    <origin xyz="0 0 0.018" rpy="0 0 0" />
    <parent link="base" />
    <child link="input_lever" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" lower="0" upper="1.1" />
    </joint>
  <joint name="input_to_relay" type="revolute">
    <origin xyz="0.11 0 0.012" rpy="0 0 0" />
    <parent link="input_lever" />
    <child link="relay_arm" />
    <axis xyz="0 0 1" />
    <limit effort="6" velocity="2.8" lower="0" upper="1.05" />
    </joint>
  <joint name="relay_to_follower" type="revolute">
    <origin xyz="0.095 0 0.012" rpy="0 0 0" />
    <parent link="relay_arm" />
    <child link="follower_arm" />
    <axis xyz="0 0 1" />
    <limit effort="5" velocity="3" lower="0" upper="0.95" />
    </joint>
  <joint name="follower_to_output" type="revolute">
    <origin xyz="0.082 0 0.012" rpy="0 0 0" />
    <parent link="follower_arm" />
    <child link="output_lever" />
    <axis xyz="0 0 1" />
    <limit effort="4" velocity="3.2" lower="0" upper="0.9" />
    </joint>
  </robot>
