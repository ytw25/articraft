<robot name="cad_parallel_finger_gripper">
  <material name="frame_gray">
    <color rgba="0.53 0.56 0.6 1" />
    </material>
  <material name="finger_gray">
    <color rgba="0.28 0.31 0.35 1" />
    </material>
  <material name="jaw_pad">
    <color rgba="0.12 0.12 0.13 1" />
    </material>
  <link name="palm">
    <inertial>
      <origin xyz="0 0 0.0025" rpy="0 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.000215267" ixy="0" ixz="0" iyy="0.00327527" iyz="0" izz="0.00339333" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/palm.obj" />
        </geometry>
      <material name="frame_gray" />
      </visual>
    </link>
  <link name="left_proximal">
    <inertial>
      <origin xyz="0 0 0.0275" rpy="0 0 0" />
      <mass value="0.14" />
      <inertia ixx="3.90717e-05" ixy="0" ixz="0" iyy="3.75783e-05" iyz="0" izz="6.06667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/proximal_segment.obj" />
        </geometry>
      <material name="finger_gray" />
      </visual>
    </link>
  <link name="left_middle">
    <inertial>
      <origin xyz="0 0 0.0225" rpy="0 0 0" />
      <mass value="0.11" />
      <inertia ixx="2.15325e-05" ixy="0" ixz="0" iyy="2.03592e-05" iyz="0" izz="4.76667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/middle_segment.obj" />
        </geometry>
      <material name="finger_gray" />
      </visual>
    </link>
  <link name="left_distal">
    <inertial>
      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <mass value="0.08" />
      <inertia ixx="8.98667e-06" ixy="0" ixz="0" iyy="8.13333e-06" iyz="0" izz="3.46667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/distal_segment.obj" />
        </geometry>
      <material name="jaw_pad" />
      </visual>
    </link>
  <link name="right_proximal">
    <inertial>
      <origin xyz="0 0 0.0275" rpy="0 0 0" />
      <mass value="0.14" />
      <inertia ixx="3.90717e-05" ixy="0" ixz="0" iyy="3.75783e-05" iyz="0" izz="6.06667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/proximal_segment.obj" />
        </geometry>
      <material name="finger_gray" />
      </visual>
    </link>
  <link name="right_middle">
    <inertial>
      <origin xyz="0 0 0.0225" rpy="0 0 0" />
      <mass value="0.11" />
      <inertia ixx="2.15325e-05" ixy="0" ixz="0" iyy="2.03592e-05" iyz="0" izz="4.76667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/middle_segment.obj" />
        </geometry>
      <material name="finger_gray" />
      </visual>
    </link>
  <link name="right_distal">
    <inertial>
      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <mass value="0.08" />
      <inertia ixx="8.98667e-06" ixy="0" ixz="0" iyy="8.13333e-06" iyz="0" izz="3.46667e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/distal_segment.obj" />
        </geometry>
      <material name="jaw_pad" />
      </visual>
    </link>
  <joint name="left_palm_to_proximal" type="revolute">
    <origin xyz="-0.09 0 0.02" rpy="0 0 0" />
    <parent link="palm" />
    <child link="left_proximal" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2.5" lower="0" upper="0.3" />
    </joint>
  <joint name="left_proximal_to_middle" type="revolute">
    <origin xyz="0 0 0.055" rpy="0 0 0" />
    <parent link="left_proximal" />
    <child link="left_middle" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="2.5" lower="0" upper="0.45" />
    </joint>
  <joint name="left_middle_to_distal" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="left_middle" />
    <child link="left_distal" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="2.5" lower="0" upper="0.35" />
    </joint>
  <joint name="right_palm_to_proximal" type="revolute">
    <origin xyz="0.09 0 0.02" rpy="0 0 3.14159" />
    <parent link="palm" />
    <child link="right_proximal" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2.5" lower="0" upper="0.3" />
    </joint>
  <joint name="right_proximal_to_middle" type="revolute">
    <origin xyz="0 0 0.055" rpy="0 0 0" />
    <parent link="right_proximal" />
    <child link="right_middle" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="2.5" lower="0" upper="0.45" />
    </joint>
  <joint name="right_middle_to_distal" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="right_middle" />
    <child link="right_distal" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="2.5" lower="0" upper="0.35" />
    </joint>
  </robot>
