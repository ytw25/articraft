<robot name="linear_carriage_spindle">
  <material name="anodized_aluminum">
    <color rgba="0.74 0.76 0.8 1" />
  </material>
  <material name="dark_polymer">
    <color rgba="0.16 0.17 0.2 1" />
  </material>
  <material name="tool_steel">
    <color rgba="0.56 0.57 0.6 1" />
  </material>
  <link name="rail_base">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <mass value="6.5" />
      <inertia ixx="0.00975" ixy="0" ixz="0" iyy="0.106817" iyz="0" izz="0.112667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/rail_base.glb" />
      </geometry>
      <material name="anodized_aluminum" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.44 0.12 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <geometry>
        <box size="0.4 0.05 0.04" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00166667" ixy="0" ixz="0" iyy="0.00225333" iyz="0" izz="0.00325333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage.glb" />
      </geometry>
      <material name="dark_polymer" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.1 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.059 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.018 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="spindle">
    <inertial>
      <origin xyz="0 0.055 0" rpy="-1.5708 0 0" />
      <mass value="0.7" />
      <inertia ixx="0.000762533" ixy="0" ixz="0" iyy="0.000762533" iyz="0" izz="0.0001134" />
    </inertial>
    <visual>
      <origin xyz="0 0.006 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.024" length="0.012" />
      </geometry>
      <material name="tool_steel" />
    </visual>
    <visual>
      <origin xyz="0 0.0495 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.018" length="0.075" />
      </geometry>
      <material name="tool_steel" />
    </visual>
    <visual>
      <origin xyz="0 0.0945 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.012" length="0.015" />
      </geometry>
      <material name="tool_steel" />
    </visual>
    <visual>
      <origin xyz="0 0.112 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.005" length="0.02" />
      </geometry>
      <material name="tool_steel" />
    </visual>
    <visual>
      <origin xyz="0 0.034 0.036" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.024 0.038" />
      </geometry>
      <material name="dark_polymer" />
    </visual>
    <collision>
      <origin xyz="0 0.051 0" rpy="-1.5708 0 0" />
      <geometry>
        <cylinder radius="0.018" length="0.098" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.034 0.036" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.024 0.038" />
      </geometry>
    </collision>
  </link>
  <joint name="rail_to_carriage" type="prismatic">
    <origin xyz="0 0 0.062" rpy="0 0 0" />
    <parent link="rail_base" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="150" velocity="0.5" lower="-0.14" upper="0.14" />
  </joint>
  <joint name="carriage_to_spindle" type="revolute">
    <origin xyz="0 0.07 0.025" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="spindle" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="8" lower="-1.4" upper="1.4" />
  </joint>
</robot>