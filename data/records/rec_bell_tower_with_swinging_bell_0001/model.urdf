    <origin xyz="0 0 0.48" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="belfry_frame" />
  </joint>
  <joint name="frame_to_roof" type="fixed">
    <origin xyz="0 0 1.96" rpy="0 0 0" />
    <parent link="belfry_frame" />
    <child link="roof" />
  </joint>
  <joint name="frame_to_bell" type="revolute">
    <origin xyz="-0.495 0 1.52" rpy="0 0 0" />
    <parent link="belfry_frame" />
    <child link="bell" />
    <axis xyz="1 0 0" />
    <limit effort="900" velocity="1.2" lower="-0.4" upper="0.4" />
  </joint>
</robot>