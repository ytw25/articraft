  <joint name="yaw_axis" type="revolute">
    <parent link="base_mount" />
    <child link="yaw_housing" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="3" lower="-2.35" upper="2.35" />
  </joint>
  <joint name="pitch_axis" type="revolute">
    <origin xyz="0.058 0 0" rpy="0 0 0" />
    <parent link="yaw_housing" />
    <child link="pitch_yoke" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="2.5" lower="-1.05" upper="1.05" />
  </joint>
  <joint name="roll_axis" type="revolute">
    <origin xyz="0.04 0 0" rpy="0 0 0" />
    <parent link="pitch_yoke" />
    <child link="roll_head" />
    <axis xyz="1 0 0" />
    <limit effort="10" velocity="6" lower="-2.4" upper="2.4" />
  </joint>
