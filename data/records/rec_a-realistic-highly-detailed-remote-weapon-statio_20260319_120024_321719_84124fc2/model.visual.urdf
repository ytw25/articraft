  <joint name="turret_pan" type="continuous">
    <origin xyz="0 0 0.28" rpy="0 0 0" />
    <parent link="mount_base" />
    <child link="turret_housing" />
    <axis xyz="0 0 1" />
    <limit effort="8000" velocity="1" />
    </joint>
  <joint name="cradle_elevation" type="revolute">
    <origin xyz="0.08 0 0.155" rpy="0 0 0" />
    <parent link="turret_housing" />
    <child link="weapon_cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="4000" velocity="1.2" lower="-0.35" upper="1.05" />
    </joint>
