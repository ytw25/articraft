<robot name="three_stage_telescoping_slide">
  <material name="outer_steel">
    <color rgba="0.28 0.3 0.33 1" />
  </material>
  <material name="middle_steel">
    <color rgba="0.56 0.58 0.6 1" />
  </material>
  <material name="inner_steel">
    <color rgba="0.73 0.74 0.76 1" />
  </material>
  <material name="machined_bracket">
    <color rgba="0.82 0.84 0.86 1" />
  </material>
  <material name="stop_feature">
    <color rgba="0.16 0.18 0.2 1" />
  </material>
  <link name="outer_rail">
    <inertial>
      <origin xyz="0.145 0 0" rpy="0 0 0" />
      <mass value="1.3" />
      <inertia ixx="0.000563767" ixy="0" ixz="0" iyy="0.0135638" iyz="0" izz="0.0135417" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/outer_rail_body.glb" />
      </geometry>
      <material name="outer_steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/outer_end_bracket.glb" />
      </geometry>
      <material name="machined_bracket" />
    </visual>
    <collision name="outer_side_pos_y">
      <origin xyz="0.15 0.0175 0" rpy="0 0 0" />
      <geometry>
        <box size="0.334 0.003 0.024" />
      </geometry>
    </collision>
    <collision name="outer_side_neg_y">
      <origin xyz="0.15 -0.0175 0" rpy="0 0 0" />
      <geometry>
        <box size="0.334 0.003 0.024" />
      </geometry>
    </collision>
    <collision name="outer_top">
      <origin xyz="0.15 0 0.0135" rpy="0 0 0" />
      <geometry>
        <box size="0.334 0.032 0.003" />
      </geometry>
    </collision>
    <collision name="outer_bottom">
      <origin xyz="0.15 0 -0.0135" rpy="0 0 0" />
      <geometry>
        <box size="0.334 0.032 0.003" />
      </geometry>
    </collision>
    <collision name="outer_end_bracket_collision">
      <origin xyz="-0.025 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.05 0.052" />
      </geometry>
    </collision>
  </link>
  <link name="middle_rail">
    <inertial>
      <origin xyz="0.12 0 0.0005" rpy="0 0 0" />
      <mass value="0.82" />
      <inertia ixx="9.05417e-05" ixy="0" ixz="0" iyy="0.00501457" iyz="0" izz="0.00503897" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/middle_rail_body.glb" />
      </geometry>
      <material name="middle_steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/middle_stop_tabs.glb" />
      </geometry>
      <material name="stop_feature" />
    </visual>
    <collision name="middle_side_pos_y">
      <origin xyz="0.12 0.01325 0" rpy="0 0 0" />
      <geometry>
        <box size="0.264 0.0025 0.016" />
      </geometry>
    </collision>
    <collision name="middle_side_neg_y">
      <origin xyz="0.12 -0.01325 0" rpy="0 0 0" />
      <geometry>
        <box size="0.264 0.0025 0.016" />
      </geometry>
    </collision>
    <collision name="middle_top">
      <origin xyz="0.12 0 0.00925" rpy="0 0 0" />
      <geometry>
        <box size="0.264 0.024 0.0025" />
      </geometry>
    </collision>
    <collision name="middle_bottom">
      <origin xyz="0.12 0 -0.00925" rpy="0 0 0" />
      <geometry>
        <box size="0.264 0.024 0.0025" />
      </geometry>
    </collision>
  </link>
  <link name="inner_rail">
    <inertial>
      <origin xyz="0.09 0 0" rpy="0 0 0" />
      <mass value="0.62" />
      <inertia ixx="0.00021018" ixy="0" ixz="0" iyy="0.00239754" iyz="0" izz="0.00236964" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/inner_rail_body.glb" />
      </geometry>
      <material name="inner_steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/inner_end_bracket.glb" />
      </geometry>
      <material name="machined_bracket" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/inner_stop_tab.glb" />
      </geometry>
      <material name="stop_feature" />
    </visual>
    <collision name="inner_side_pos_y">
      <origin xyz="0.085 0.009 0" rpy="0 0 0" />
      <geometry>
        <box size="0.194 0.002 0.008" />
      </geometry>
    </collision>
    <collision name="inner_side_neg_y">
      <origin xyz="0.085 -0.009 0" rpy="0 0 0" />
      <geometry>
        <box size="0.194 0.002 0.008" />
      </geometry>
    </collision>
    <collision name="inner_top">
      <origin xyz="0.085 0 0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.194 0.016 0.002" />
      </geometry>
    </collision>
    <collision name="inner_bottom">
      <origin xyz="0.085 0 -0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.194 0.016 0.002" />
      </geometry>
    </collision>
    <collision name="inner_end_bracket_collision">
      <origin xyz="0.19 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.042 0.048" />
      </geometry>
    </collision>
  </link>
  <joint name="outer_to_middle" type="prismatic">
    <parent link="outer_rail" />
    <child link="middle_rail" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.6" lower="0" upper="0.22" />
  </joint>
  <joint name="middle_to_inner" type="prismatic">
    <origin xyz="0.138 0 0" rpy="0 0 0" />
    <parent link="middle_rail" />
    <child link="inner_rail" />
    <axis xyz="1 0 0" />
    <limit effort="65" velocity="0.6" lower="0" upper="0.095" />
  </joint>
</robot>