<robot name="overhung_mechanical_arm">
  <material name="pedestal_gray">
    <color rgba="0.32 0.34 0.37 1" />
  </material>
  <material name="actuator_dark">
    <color rgba="0.15 0.16 0.18 1" />
  </material>
  <material name="beam_blue">
    <color rgba="0.18 0.34 0.68 1" />
  </material>
  <material name="tool_orange">
    <color rgba="0.92 0.48 0.14 1" />
  </material>
  <link name="pedestal">
    <inertial>
      <mass value="18" />
      <inertia ixx="0.2076" ixy="0" ixz="0" iyy="0.2364" iyz="0" izz="0.174" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pedestal.glb" />
      </geometry>
      <material name="pedestal_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.26 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.18 0.25" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.16 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="yaw_housing">
    <inertial>
      <origin xyz="0.01 0 0.065" rpy="0 0 0" />
      <mass value="4.2" />
      <inertia ixx="0.019915" ixy="0" ixz="0" iyy="0.017255" iyz="0" izz="0.02534" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/yaw_housing.glb" />
      </geometry>
      <material name="actuator_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.2 0.08" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.12 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0 0.08" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.12 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.21 0 0" rpy="0 0 0" />
      <mass value="4.8" />
      <inertia ixx="0.01152" ixy="0" ixz="0" iyy="0.07632" iyz="0" izz="0.07632" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="beam_blue" />
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.14 0.14" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.22 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.05 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.36 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.17 0 -0.005" rpy="0 0 0" />
      <mass value="3.2" />
      <inertia ixx="0.00589333" ixy="0" ixz="0" iyy="0.0334933" iyz="0" izz="0.0340533" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="beam_blue" />
    </visual>
    <collision>
      <origin xyz="0.045 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.11 0.11" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.17 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.05 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.315 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.09 0.09" />
      </geometry>
    </collision>
  </link>
  <link name="tool_head">
    <inertial>
      <origin xyz="0.11 0 0" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.00150333" ixy="0" ixz="0" iyy="0.00502333" iyz="0" izz="0.00535333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_head.glb" />
      </geometry>
      <material name="tool_orange" />
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.08 0.08" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.04 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.17 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.1 0.08" />
      </geometry>
    </collision>
  </link>
  <joint name="pedestal_to_turret" type="revolute">
    <origin xyz="0 0 0.17" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="yaw_housing" />
    <axis xyz="0 0 1" />
    <limit effort="60" velocity="1.5" lower="-1.6" upper="1.6" />
  </joint>
  <joint name="turret_to_upper_arm" type="revolute">
    <origin xyz="0.12 0 0.08" rpy="0 0 0" />
    <parent link="yaw_housing" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1.5" lower="-0.25" upper="1.05" />
  </joint>
  <joint name="upper_arm_to_forearm" type="revolute">
    <origin xyz="0.4 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.8" lower="-0.15" upper="1.55" />
  </joint>
  <joint name="forearm_to_tool" type="revolute">
    <origin xyz="0.34 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="tool_head" />
    <axis xyz="0 0 1" />
    <limit effort="15" velocity="2.5" lower="-1.15" upper="1.15" />
  </joint>
</robot>