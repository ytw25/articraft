<robot name="z_axis_wrist_module">
  <material name="painted_steel">
    <color rgba="0.3 0.33 0.36 1" />
  </material>
  <material name="ground_rail">
    <color rgba="0.74 0.76 0.79 1" />
  </material>
  <material name="machine_gray">
    <color rgba="0.56 0.58 0.6 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.88 0.5 0.12 1" />
  </material>
  <link name="column">
    <inertial>
      <origin xyz="0 -0.006 0.25" rpy="0 0 0" />
      <mass value="11" />
      <inertia ixx="0.247133" ixy="0" ixz="0" iyy="0.273533" iyz="0" izz="0.0623333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/column.glb" />
      </geometry>
      <material name="machine_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.14 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.02 0.26" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.014 0.44" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.005 0.4925" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.05 0.025" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0.022 0" rpy="0 0 0" />
      <mass value="2.6" />
      <inertia ixx="0.002535" ixy="0" ixz="0" iyy="0.00663" iyz="0" izz="0.005655" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage.glb" />
      </geometry>
      <material name="painted_steel" />
    </visual>
    <collision>
      <origin xyz="0 0.018 0" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.024 0.086" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.046 0" rpy="0 0 0" />
      <geometry>
        <box size="0.072 0.028 0.072" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.06 0" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.048 0.048" />
      </geometry>
    </collision>
  </link>
  <link name="wrist">
    <inertial>
      <origin xyz="0 0.0605 0" rpy="0 0 0" />
      <mass value="1.4" />
      <inertia ixx="0.00245478" ixy="0" ixz="0" iyy="0.00191333" iyz="0" izz="0.00287478" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/wrist.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <origin xyz="0 0.007 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.014 0.06" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.033 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.06 0.06" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.074 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.08 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.115 0" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.012 0.052" />
      </geometry>
    </collision>
  </link>
  <joint name="z_slide" type="prismatic">
    <origin xyz="0 -0.004 0.16" rpy="0 0 0" />
    <parent link="column" />
    <child link="carriage" />
    <axis xyz="0 0 1" />
    <limit effort="900" velocity="0.35" lower="0" upper="0.22" />
  </joint>
  <joint name="wrist_pitch" type="revolute">
    <origin xyz="0 0.06 0" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="wrist" />
    <axis xyz="1 0 0" />
    <limit effort="45" velocity="2.5" lower="-0.85" upper="0.9" />
  </joint>
</robot>