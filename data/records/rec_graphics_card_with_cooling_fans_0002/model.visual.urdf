<robot name="graphics_card">
  <material name="shroud_black">
    <color rgba="0.1 0.1 0.11 1" />
    </material>
  <material name="graphite">
    <color rgba="0.23 0.24 0.27 1" />
    </material>
  <material name="brushed_aluminum">
    <color rgba="0.66 0.68 0.72 1" />
    </material>
  <material name="fan_black">
    <color rgba="0.08 0.08 0.09 1" />
    </material>
  <material name="gold_contact">
    <color rgba="0.86 0.72 0.25 1" />
    </material>
  <material name="trim_metal">
    <color rgba="0.47 0.49 0.53 1" />
    </material>
  <material name="bracket_metal">
    <color rgba="0.71 0.73 0.76 1" />
    </material>
  <link name="gpu_body">
    <inertial>
      <mass value="1.55" />
      <inertia ixx="0.00214778" ixy="0" ixz="0" iyy="0.0125121" iyz="0" izz="0.0110629" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_shroud.obj" />
        </geometry>
      <material name="shroud_black" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_backplate.obj" />
        </geometry>
      <material name="graphite" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_heatsink.obj" />
        </geometry>
      <material name="brushed_aluminum" />
      </visual>
    <visual>
      <origin xyz="-0.022 -0.006 -0.058" rpy="0 0 0" />
      <geometry>
        <box size="0.072 0.006 0.01" />
        </geometry>
      <material name="gold_contact" />
      </visual>
    <visual>
      <origin xyz="0.01 0.0245 0.044" rpy="0 0 0" />
      <geometry>
        <box size="0.172 0.0025 0.006" />
        </geometry>
      <material name="trim_metal" />
      </visual>
    </link>
  <link name="bracket">
    <inertial>
      <origin xyz="-0.003 0 0" rpy="0 0 0" />
      <mass value="0.08" />
      <inertia ixx="9.84067e-05" ixy="0" ixz="0" iyy="9.64267e-05" iyz="0" izz="2.83333e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_bracket.obj" />
        </geometry>
      <material name="bracket_metal" />
      </visual>
    </link>
  <link name="fan_left">
    <inertial>
      <mass value="0.035" />
      <inertia ixx="1.281e-05" ixy="0" ixz="0" iyy="2.541e-05" iyz="0" izz="1.281e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_fan_rotor.obj" />
        </geometry>
      <material name="fan_black" />
      </visual>
    </link>
  <link name="fan_center">
    <inertial>
      <mass value="0.035" />
      <inertia ixx="1.281e-05" ixy="0" ixz="0" iyy="2.541e-05" iyz="0" izz="1.281e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_fan_rotor.obj" />
        </geometry>
      <material name="fan_black" />
      </visual>
    </link>
  <link name="fan_right">
    <inertial>
      <mass value="0.035" />
      <inertia ixx="1.281e-05" ixy="0" ixz="0" iyy="2.541e-05" iyz="0" izz="1.281e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/gpu_fan_rotor.obj" />
        </geometry>
      <material name="fan_black" />
      </visual>
    </link>
  <joint name="body_to_bracket" type="fixed">
    <origin xyz="-0.143 0 0" rpy="0 0 0" />
    <parent link="gpu_body" />
    <child link="bracket" />
    </joint>
  <joint name="fan_left_spin" type="continuous">
    <origin xyz="-0.086 0.013 0" rpy="0 0 0" />
    <parent link="gpu_body" />
    <child link="fan_left" />
    <axis xyz="0 1 0" />
    <limit effort="0.25" velocity="120" />
    </joint>
  <joint name="fan_center_spin" type="continuous">
    <origin xyz="0 0.013 0" rpy="0 0 0" />
    <parent link="gpu_body" />
    <child link="fan_center" />
    <axis xyz="0 1 0" />
    <limit effort="0.25" velocity="120" />
    </joint>
  <joint name="fan_right_spin" type="continuous">
    <origin xyz="0.086 0.013 0" rpy="0 0 0" />
    <parent link="gpu_body" />
    <child link="fan_right" />
    <axis xyz="0 1 0" />
    <limit effort="0.25" velocity="120" />
    </joint>
  </robot>
