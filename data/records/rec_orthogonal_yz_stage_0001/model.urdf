<robot name="compact_yz_positioner">
  <material name="base_steel">
    <color rgba="0.45 0.47 0.5 1" />
  </material>
  <material name="machined_aluminum">
    <color rgba="0.79 0.81 0.84 1" />
  </material>
  <material name="anodized_dark">
    <color rgba="0.2 0.21 0.24 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <mass value="3.2" />
      <inertia ixx="0.00884907" ixy="0" ixz="0" iyy="0.00884907" iyz="0" izz="0.01728" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="base_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.18 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.046 0 0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.15 0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.046 0 0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.15 0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.14 0.01" />
      </geometry>
    </collision>
  </link>
  <link name="y_carriage">
    <inertial>
      <origin xyz="0.01 0 0.06" rpy="0 0 0" />
      <mass value="1.15" />
      <inertia ixx="0.001725" ixy="0" ixz="0" iyy="0.0018768" iyz="0" izz="0.0008418" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/y_carriage.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.026 0.056 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.026 0 0.075" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.054 0.11" />
      </geometry>
    </collision>
  </link>
  <link name="z_slide">
    <inertial>
      <origin xyz="0.009 0 0" rpy="0 0 0" />
      <mass value="0.55" />
      <inertia ixx="0.0002706" ixy="0" ixz="0" iyy="0.00017985" iyz="0" izz="0.00012045" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/z_slide.glb" />
      </geometry>
      <material name="machined_aluminum" />
    </visual>
    <collision>
      <origin xyz="0.009 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.044 0.056" />
      </geometry>
    </collision>
  </link>
  <link name="tool_platform">
    <inertial>
      <origin xyz="0.02 0 0" rpy="0 0 0" />
      <mass value="0.22" />
      <inertia ixx="6.46067e-05" ixy="0" ixz="0" iyy="4.81067e-05" iyz="0" izz="7.51667e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_platform.glb" />
      </geometry>
      <material name="anodized_dark" />
    </visual>
    <collision>
      <origin xyz="0.004 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.008 0.022 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.048 0.01" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_y_carriage" type="prismatic">
    <origin xyz="0 0 0.022" rpy="0 0 0" />
    <parent link="base" />
    <child link="y_carriage" />
    <axis xyz="0 1 0" />
    <limit effort="80" velocity="0.4" lower="-0.045" upper="0.045" />
  </joint>
  <joint name="y_carriage_to_z_slide" type="prismatic">
    <origin xyz="0.032 0 0.05" rpy="0 0 0" />
    <parent link="y_carriage" />
    <child link="z_slide" />
    <axis xyz="0 0 1" />
    <limit effort="60" velocity="0.3" lower="0" upper="0.05" />
  </joint>
  <joint name="z_slide_to_tool_platform" type="fixed">
    <origin xyz="0.018 0 0" rpy="0 0 0" />
    <parent link="z_slide" />
    <child link="tool_platform" />
  </joint>
</robot>