  <joint name="base_mount" type="fixed">
    <origin xyz="0 0 0.036" rpy="0 0 0" />
    <parent link="base" />
    <child link="upright" />
    </joint>
  <joint name="head_tilt" type="revolute">
    <origin xyz="0.056 0 1.39" rpy="0 0 0" />
    <parent link="upright" />
    <child link="head" />
    <axis xyz="0 -1 0" />
    <limit effort="8" velocity="1.2" lower="-0.9" upper="0.55" />
    </joint>
  </robot>
