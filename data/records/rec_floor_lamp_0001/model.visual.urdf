<robot name="floor_lamp">
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <mass value="8.5" />
      <inertia ixx="0.0561765" ixy="0" ixz="0" iyy="0.0561765" iyz="0" izz="0.111537" />
      </inertial>
    <visual name="floor_ring">
