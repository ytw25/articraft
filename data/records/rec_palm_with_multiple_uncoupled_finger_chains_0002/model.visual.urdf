  <link name="finger_bottom_inner">
    <inertial>
      <origin xyz="0.01725 0 0" rpy="0 0 0" />
      <mass value="0.028" />
      <inertia ixx="4.2e-07" ixy="0" ixz="0" iyy="5.12925e-06" iyz="0" izz="5.38125e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/finger_plate.obj" />
        </geometry>
      <material name="finger_plate" />
