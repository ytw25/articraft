    </material>
  <link name="palm">
    <inertial>
      <mass value="0.22" />
      <inertia ixx="0.000124447" ixy="0" ixz="0" iyy="4.70067e-05" iyz="0" izz="0.000169107" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/palm_plate.obj" />
