<robot name="machine_tool_linear_stage">
  <material name="rail_steel">
    <color rgba="0.6 0.63 0.68 1" />
  </material>
  <material name="carriage_steel">
    <color rgba="0.72 0.74 0.78 1" />
  </material>
  <material name="wiper_black">
    <color rgba="0.08 0.08 0.09 1" />
  </material>
  <link name="rail">
    <inertial>
      <origin xyz="0 0 -0.006" rpy="0 0 0" />
      <mass value="3.2" />
      <inertia ixx="0.000311467" ixy="0" ixz="0" iyy="0.0470784" iyz="0" izz="0.0473131" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/linear_stage_rail.glb" />
      </geometry>
      <material name="rail_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.42 0.032 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0 0.019" rpy="0 0 0" />
      <mass value="1" />
      <inertia ixx="0.000440667" ixy="0" ixz="0" iyy="0.000795333" iyz="0" izz="0.000995333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/linear_stage_carriage.glb" />
      </geometry>
      <material name="carriage_steel" />
    </visual>
    <visual>
      <origin xyz="0.043 0 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.0558 0.016" />
      </geometry>
      <material name="wiper_black" />
    </visual>
    <visual>
      <origin xyz="-0.043 0 0.008" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.0558 0.016" />
      </geometry>
      <material name="wiper_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.019" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.062 0.038" />
      </geometry>
    </collision>
  </link>
  <joint name="rail_to_carriage" type="prismatic">
    <parent link="rail" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="1500" velocity="0.4" lower="-0.12" upper="0.12" />
  </joint>
</robot>