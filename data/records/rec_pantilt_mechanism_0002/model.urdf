<robot name="inspection_pan_tilt">
  <material name="powder_black">
    <color rgba="0.12 0.12 0.13 1" />
  </material>
  <material name="anodized_gray">
    <color rgba="0.38 0.4 0.43 1" />
  </material>
  <material name="sensor_glass">
    <color rgba="0.34 0.54 0.66 0.65" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.000348267" ixy="0" ixz="0" iyy="0.0005616" iyz="0" izz="0.000866667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="anodized_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.07 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.013" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.018" length="0.01" />
      </geometry>
    </collision>
  </link>
  <link name="pan_yoke">
    <inertial>
      <origin xyz="0 0 0.034" rpy="0 0 0" />
      <mass value="0.45" />
      <inertia ixx="0.00028275" ixy="0" ixz="0" iyy="0.00031755" iyz="0" izz="0.0002535" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pan_yoke.glb" />
      </geometry>
      <material name="powder_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.028" length="0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <geometry>
        <box size="0.062 0.054 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.022 0.043" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.008 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.022 0.043" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.008 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="sensor_head">
    <inertial>
      <origin xyz="-0.02 0 0" rpy="0 0 0" />
      <mass value="0.22" />
      <inertia ixx="4.25333e-05" ixy="0" ixz="0" iyy="0.0001188" iyz="0" izz="0.000113813" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/sensor_head.glb" />
      </geometry>
      <material name="anodized_gray" />
    </visual>
    <visual>
      <origin xyz="-0.068 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0095" length="0.0035" />
      </geometry>
      <material name="sensor_glass" />
    </visual>
    <collision>
      <origin xyz="-0.02 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.058 0.032 0.036" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.056 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.011" length="0.014" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_pan" type="revolute">
    <origin xyz="0 0 0.019" rpy="0 0 0" />
    <parent link="base" />
    <child link="pan_yoke" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" lower="-2.8" upper="2.8" />
  </joint>
  <joint name="pan_to_sensor" type="revolute">
    <origin xyz="0 0 0.054" rpy="0 0 0" />
    <parent link="pan_yoke" />
    <child link="sensor_head" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="2" lower="-0.7" upper="1" />
  </joint>
</robot>