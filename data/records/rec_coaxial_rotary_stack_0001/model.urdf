<robot name="nested_industrial_turntable">
  <material name="machine_base">
    <color rgba="0.2 0.22 0.24 1" />
  </material>
  <material name="bearing_steel">
    <color rgba="0.62 0.65 0.69 1" />
  </material>
  <material name="tooling_orange">
    <color rgba="0.83 0.39 0.1 1" />
  </material>
  <link name="pedestal_base">
    <inertial>
      <origin xyz="0 0 -0.09" rpy="0 0 0" />
      <mass value="18" />
      <inertia ixx="0.143212" ixy="0" ixz="0" iyy="0.143212" iyz="0" izz="0.189225" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pedestal_base.glb" />
      </geometry>
      <material name="machine_base" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.149" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.16" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.105" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.136" length="0.086" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.038" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.118" length="0.048" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.19" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.04" />
      </geometry>
    </collision>
  </link>
  <link name="slew_carrier">
    <inertial>
      <origin xyz="0 0 0.028" rpy="0 0 0" />
      <mass value="7.5" />
      <inertia ixx="0.04975" ixy="0" ixz="0" iyy="0.04975" iyz="0" izz="0.084375" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/slew_carrier.glb" />
      </geometry>
      <material name="bearing_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.012" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.176" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.034" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.146" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.034 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.1 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.034 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.1 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.034 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.032 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.034 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.032 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.046" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.09" length="0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.014" length="0.038" />
      </geometry>
    </collision>
  </link>
  <link name="top_platter">
    <inertial>
      <origin xyz="0 0 0.024" rpy="0 0 0" />
      <mass value="4.2" />
      <inertia ixx="0.0171069" ixy="0" ixz="0" iyy="0.0171069" iyz="0" izz="0.0312564" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/top_platter.glb" />
      </geometry>
      <material name="tooling_orange" />
    </visual>
    <collision>
      <origin xyz="0.033 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.096 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.033 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.096 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.033 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.03 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.033 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.03 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.026" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.122" length="0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.042" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.106" length="0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.052" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.03" length="0.01" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_slew" type="revolute">
    <parent link="pedestal_base" />
    <child link="slew_carrier" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="1.2" lower="-2.6" upper="2.6" />
  </joint>
  <joint name="slew_to_platter" type="revolute">
    <origin xyz="0 0 0.06" rpy="0 0 0" />
    <parent link="slew_carrier" />
    <child link="top_platter" />
    <axis xyz="0 0 1" />
    <limit effort="45" velocity="2" lower="-3" upper="3" />
  </joint>
</robot>