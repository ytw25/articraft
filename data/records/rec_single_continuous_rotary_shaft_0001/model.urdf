<robot name="pottery_wheel">
  <material name="body_gray">
    <color rgba="0.26 0.28 0.31 1" />
  </material>
  <material name="trim_black">
    <color rgba="0.08 0.08 0.09 1" />
  </material>
  <material name="steel">
    <color rgba="0.72 0.74 0.77 1" />
  </material>
  <material name="wheelhead">
    <color rgba="0.8 0.82 0.84 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.155" rpy="0 0 0" />
      <mass value="18" />
      <inertia ixx="0.29775" ixy="0" ixz="0" iyy="0.43455" iyz="0" izz="0.444" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pottery_wheel_base.glb" />
      </geometry>
      <material name="body_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.09" rpy="0 0 0" />
      <geometry>
        <box size="0.44 0.32 0.18" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.23" rpy="0 0 0" />
      <geometry>
        <box size="0.36 0.26 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.289" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.16" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.294" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.018" length="0.028" />
      </geometry>
    </collision>
  </link>
  <link name="shaft">
    <inertial>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <mass value="0.6" />
      <inertia ixx="5.36e-05" ixy="0" ixz="0" iyy="5.36e-05" iyz="0" izz="5.88e-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.014" length="0.022" />
      </geometry>
      <material name="steel" />
    </visual>
    <visual>
      <origin xyz="0.02 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.008 0.01" />
      </geometry>
      <material name="steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.014" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.02 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.008 0.01" />
      </geometry>
    </collision>
  </link>
  <link name="wheelhead">
    <inertial>
      <origin xyz="0 0 0.019" rpy="0 0 0" />
      <mass value="4.8" />
      <inertia ixx="0.0240976" ixy="0" ixz="0" iyy="0.0240976" iyz="0" izz="0.04704" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pottery_wheel_head.glb" />
      </geometry>
      <material name="wheelhead" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.03" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.028" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.14" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_shaft" type="continuous">
    <origin xyz="0 0 0.308" rpy="0 0 0" />
    <parent link="base" />
    <child link="shaft" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="12" />
  </joint>
  <joint name="shaft_to_wheelhead" type="fixed">
    <origin xyz="0 0 0.022" rpy="0 0 0" />
    <parent link="shaft" />
    <child link="wheelhead" />
  </joint>
</robot>