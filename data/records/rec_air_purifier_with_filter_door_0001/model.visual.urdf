      <geometry>
        <cylinder radius="0.01" length="0.012" />
        </geometry>
      <material name="rubber">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    <visual name="front_right_foot">
      <origin xyz="0.1 0.055 0.006" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.012" />
        </geometry>
      <material name="rubber">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    </link>
  <link name="front_intake">
