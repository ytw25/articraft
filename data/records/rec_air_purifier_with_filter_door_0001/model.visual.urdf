      <origin xyz="0 0 0.003" rpy="0 0 0" />
      <mass value="0.22" />
      <inertia ixx="0.000101053" ixy="0" ixz="0" iyy="0.00041316" iyz="0" izz="0.000512893" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/control_pod.obj" />
        </geometry>
      <material name="glass_black">
        <color rgba="0.09 0.1 0.11 0.96" />
        </material>
      </visual>
    <visual name="power_switch_bezel">
      <origin xyz="0.044 0 0.0052" rpy="0 0 0" />
      <geometry>
        <box size="0.038 0.058 0.0024" />
        </geometry>
      <material name="warm_gray">
        <color rgba="0.78 0.79 0.8 1" />
        </material>
      </visual>
    </link>
  <link name="filter_door">
    <inertial>
      <origin xyz="-0.118 -0.005 0" rpy="0 0 0" />
      <mass value="0.95" />
      <inertia ixx="0.00713292" ixy="0" ixz="0" iyy="0.0115343" iyz="0" izz="0.00441718" />
      </inertial>
    <visual>
      <origin xyz="-0.118 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/filter_door.obj" />
        </geometry>
      <material name="body_white">
        <color rgba="0.94 0.95 0.96 1" />
        </material>
      </visual>
    <visual>
      <origin xyz="-0.118 -0.003 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/filter_insert.obj" />
        </geometry>
      <material name="warm_gray">
        <color rgba="0.78 0.79 0.8 1" />
        </material>
      </visual>
    <visual name="finger_pull">
      <origin xyz="-0.226 -0.006 0.078" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.003 0.05" />
        </geometry>
      <material name="vent_dark">
        <color rgba="0.19 0.21 0.23 1" />
