  <link name="selector_dial">
    <inertial>
      <origin xyz="0 0 0.0125" rpy="0 0 0" />
      <mass value="0.12" />
      <inertia ixx="3.508e-05" ixy="0" ixz="0" iyy="3.508e-05" iyz="0" izz="5.766e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/selector_dial.obj" />
        </geometry>
      <material name="glass_black">
        <color rgba="0.09 0.1 0.11 0.96" />
        </material>
      </visual>
    <visual name="dial_trim_ring">
      <origin xyz="0 0 0.001" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.031" length="0.002" />
        </geometry>
      <material name="steel">
        <color rgba="0.73 0.75 0.78 1" />
        </material>
      </visual>
    <visual name="dial_indicator">
      <origin xyz="0 0.018 0.024" rpy="0 0 0" />
      <geometry>
        <box size="0.003 0.012 0.0014" />
        </geometry>
      <material name="steel">
        <color rgba="0.73 0.75 0.78 1" />
        </material>
      </visual>
    </link>
  <link name="power_rocker">
    <inertial>
      <origin xyz="0 0 0.004" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1.06833e-05" ixy="0" ixz="0" iyy="4.01667e-06" iyz="0" izz="1.41667e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/power_rocker.obj" />
        </geometry>
      <material name="vent_dark">
        <color rgba="0.19 0.21 0.23 1" />
        </material>
      </visual>
    <visual name="power_mark">
      <origin xyz="0 0.012 0.0085" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.014 0.0015" />
        </geometry>
      <material name="steel">
        <color rgba="0.73 0.75 0.78 1" />
        </material>
      </visual>
    </link>
  <joint name="body_to_front_intake" type="fixed">
    <origin xyz="0 0.105 0.205" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="front_intake" />
    </joint>
  <joint name="body_to_top_grille" type="fixed">
    <origin xyz="0 -0.036 0.5508" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="top_grille" />
    </joint>
  <joint name="body_to_control_pod" type="fixed">
    <origin xyz="0 0.048 0.5515" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="control_pod" />
    </joint>
  <joint name="body_to_filter_door" type="revolute">
    <origin xyz="0.12 -0.1045 0.22" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="filter_door" />
    <axis xyz="0 0 1" />
    <limit effort="9" velocity="2.5" lower="0" upper="1.25" />
    </joint>
  <joint name="control_pod_to_selector_dial" type="continuous">
    <origin xyz="-0.036 0 0.0096" rpy="0 0 0" />
    <parent link="control_pod" />
    <child link="selector_dial" />
    <axis xyz="0 0 1" />
    <limit effort="1" velocity="5" />
    </joint>
  <joint name="control_pod_to_power_rocker" type="revolute">
    <origin xyz="0.044 0 0.0123" rpy="0 0 0" />
    <parent link="control_pod" />
    <child link="power_rocker" />
    <axis xyz="1 0 0" />
    <limit effort="0.6" velocity="3" lower="-0.18" upper="0.18" />
    </joint>
  </robot>
