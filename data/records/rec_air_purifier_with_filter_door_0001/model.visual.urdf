    <color rgba="0.09 0.1 0.11 0.96" />
    </material>
  <material name="steel">
    <color rgba="0.73 0.75 0.78 1" />
    </material>
  <material name="rubber">
    <color rgba="0.1 0.1 0.11 1" />
