  <link name="body_shell">
    <inertial>
      <origin xyz="0 0 0.28" rpy="0 0 0" />
      <mass value="8.1" />
      <inertia ixx="0.23868" ixy="0" ixz="0" iyy="0.27243" iyz="0" izz="0.08775" />
      </inertial>
    <visual>
