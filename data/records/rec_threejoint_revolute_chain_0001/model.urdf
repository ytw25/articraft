<robot name="task_arm">
  <material name="base_gray">
    <color rgba="0.23 0.24 0.27 1" />
  </material>
  <material name="arm_silver">
    <color rgba="0.77 0.79 0.83 1" />
  </material>
  <material name="pad_black">
    <color rgba="0.11 0.12 0.13 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.062" rpy="0 0 0" />
      <mass value="4.5" />
      <inertia ixx="0.015366" ixy="0" ixz="0" iyy="0.017916" iyz="0" izz="0.02175" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base.glb" />
      </geometry>
      <material name="base_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.16 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.074" rpy="0 0 0" />
      <geometry>
        <box size="0.078 0.082 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.13 0 0" rpy="0 0 0" />
      <mass value="1.2" />
      <inertia ixx="0.0003625" ixy="0" ixz="0" iyy="0.00692" iyz="0" izz="0.0069625" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="arm_silver" />
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.042 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.13 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.172 0.032 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.26 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.042 0.03" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.11 0 0" rpy="0 0 0" />
      <mass value="0.95" />
      <inertia ixx="0.000229267" ixy="0" ixz="0" iyy="0.00393427" iyz="0" izz="0.00395833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="arm_silver" />
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.042 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.11 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.138 0.03 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.22 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.042 0.03" />
      </geometry>
    </collision>
  </link>
  <link name="wrist_pad">
    <inertial>
      <origin xyz="0.0555 0 0" rpy="0 0 0" />
      <mass value="0.45" />
      <inertia ixx="0.00022875" ixy="0" ixz="0" iyy="0.000555788" iyz="0" izz="0.000597038" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/wrist_body.glb" />
      </geometry>
      <material name="arm_silver" />
    </visual>
    <visual>
      <origin xyz="0.105 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.09 0.06" />
      </geometry>
      <material name="pad_black" />
    </visual>
    <collision>
      <geometry>
        <box size="0.028 0.038 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.045 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.024 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.105 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.09 0.06" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder" type="revolute">
    <origin xyz="0 0 0.124" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1.6" lower="-0.55" upper="1.35" />
  </joint>
  <joint name="elbow" type="revolute">
    <origin xyz="0.26 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="30" velocity="1.8" lower="0" upper="1.95" />
  </joint>
  <joint name="wrist" type="revolute">
    <origin xyz="0.22 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist_pad" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="2.2" lower="-0.8" upper="0.95" />
  </joint>
</robot>