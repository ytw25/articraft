<robot name="rotary_tree_mechanism">
  <material name="hub_gray">
    <color rgba="0.58 0.6 0.63 1" />
    </material>
  <material name="arm_blue">
    <color rgba="0.23 0.45 0.72 1" />
    </material>
  <link name="hub">
    <inertial>
      <mass value="1.15" />
      <inertia ixx="0.0008878" ixy="0" ixz="0" iyy="0.0008878" iyz="0" izz="0.0012167" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/rotary_tree_hub.obj" />
        </geometry>
      <material name="hub_gray" />
      </visual>
    </link>
  <link name="arm_a">
    <inertial>
      <origin xyz="0.082 0 0" rpy="0 0 0" />
      <mass value="0.24" />
      <inertia ixx="2.768e-05" ixy="0" ixz="0" iyy="0.0004964" iyz="0" izz="0.00050472" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/rotary_tree_arm.obj" />
        </geometry>
      <material name="arm_blue" />
      </visual>
    </link>
  <link name="arm_b">
    <inertial>
      <origin xyz="0.082 0 0" rpy="0 0 0" />
      <mass value="0.24" />
      <inertia ixx="2.768e-05" ixy="0" ixz="0" iyy="0.0004964" iyz="0" izz="0.00050472" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/rotary_tree_arm.obj" />
        </geometry>
      <material name="arm_blue" />
      </visual>
