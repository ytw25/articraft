<robot name="reading_lamp">
  <material name="powder_black">
    <color rgba="0.12 0.12 0.14 1" />
  </material>
  <material name="warm_brass">
    <color rgba="0.66 0.56 0.29 1" />
  </material>
  <material name="shade_cream">
    <color rgba="0.93 0.91 0.84 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.0067144" ixy="0" ixz="0" iyy="0.0067144" iyz="0" izz="0.01331" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/lamp_base.glb" />
      </geometry>
      <material name="powder_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.11" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.073" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.017" length="0.11" />
      </geometry>
    </collision>
  </link>
  <link name="lower_arm">
    <inertial>
      <origin xyz="0.135 0 0" rpy="0 0 0" />
      <mass value="0.42" />
      <inertia ixx="4.032e-05" ixy="0" ixz="0" iyy="0.00238616" iyz="0" izz="0.00238616" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/lower_arm.glb" />
      </geometry>
      <material name="warm_brass" />
    </visual>
    <collision>
      <origin xyz="0.13 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.018 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0285 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.018 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.27 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.02 0.02" />
      </geometry>
    </collision>
  </link>
  <link name="upper_assembly">
    <inertial>
      <origin xyz="0.168 0 -0.018" rpy="0 0 0" />
      <mass value="0.48" />
      <inertia ixx="0.00035136" ixy="0" ixz="0" iyy="0.003865" iyz="0" izz="0.00392836" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm_frame.glb" />
      </geometry>
      <material name="warm_brass" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/lamp_shade.glb" />
      </geometry>
      <material name="shade_cream" />
    </visual>
    <collision>
      <origin xyz="0.102 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.182 0.016 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.01 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.018 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.248 0 -0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.092 0.072 0.05" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_lower_arm" type="revolute">
    <origin xyz="0 0 0.128" rpy="0 0 0" />
    <parent link="base" />
    <child link="lower_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.4" lower="-0.1" upper="1.15" />
  </joint>
  <joint name="lower_arm_to_upper_assembly" type="revolute">
    <origin xyz="0.28 0 0" rpy="0 0 0" />
    <parent link="lower_arm" />
    <child link="upper_assembly" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="1.6" lower="-1.05" upper="1.05" />
  </joint>
</robot>