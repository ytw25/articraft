<robot name="offset_axis_rotary_stack">
  <material name="frame_dark">
    <color rgba="0.16 0.18 0.2 1" />
    </material>
  <material name="module_gray">
    <color rgba="0.44 0.46 0.49 1" />
    </material>
  <material name="accent_blue">
    <color rgba="0.18 0.38 0.74 1" />
    </material>
  <material name="tool_light">
    <color rgba="0.73 0.76 0.8 1" />
    </material>
  <link name="base_frame">
    <inertial>
      <origin xyz="0 0 -0.03" rpy="0 0 0" />
      <mass value="1.45" />
      <inertia ixx="0.00192657" ixy="0" ixz="0" iyy="0.00292417" iyz="0" izz="0.00192657" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_frame.obj" />
        </geometry>
      <material name="frame_dark" />
      </visual>
    </link>
  <link name="stage1_carrier">
    <inertial>
      <origin xyz="0.055 0 0.008" rpy="0 0 0" />
      <mass value="0.95" />
      <inertia ixx="0.00109598" ixy="0" ixz="0" iyy="0.00335667" iyz="0" izz="0.00286932" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage1_carrier.obj" />
        </geometry>
      <material name="module_gray" />
      </visual>
    </link>
  <link name="stage2_carrier">
    <inertial>
      <origin xyz="0.045 0 -0.004" rpy="0 0 0" />
      <mass value="0.74" />
      <inertia ixx="0.000693133" ixy="0" ixz="0" iyy="0.00175263" iyz="0" izz="0.00153359" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage2_carrier.obj" />
        </geometry>
      <material name="accent_blue" />
      </visual>
    </link>
  <link name="stage3_platform">
    <inertial>
      <origin xyz="0.046 0 0.018" rpy="0 0 0" />
      <mass value="0.48" />
      <inertia ixx="0.00040976" ixy="0" ixz="0" iyy="0.000832" iyz="0" izz="0.00072976" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage3_platform.obj" />
        </geometry>
      <material name="tool_light" />
      </visual>
    </link>
  <joint name="base_to_stage1" type="revolute">
    <parent link="base_frame" />
    <child link="stage1_carrier" />
    <axis xyz="0 1 0" />
    <limit effort="18" velocity="2.4" lower="-1.15" upper="1.2" />
    </joint>
  <joint name="stage1_to_stage2" type="revolute">
    <origin xyz="0.135 0 0.045" rpy="0 0 0" />
    <parent link="stage1_carrier" />
    <child link="stage2_carrier" />
    <axis xyz="0 1 0" />
    <limit effort="15" velocity="2.8" lower="-1.35" upper="1.05" />
    </joint>
  <joint name="stage2_to_stage3" type="revolute">
    <origin xyz="0.11 0 -0.038" rpy="0 0 0" />
    <parent link="stage2_carrier" />
    <child link="stage3_platform" />
    <axis xyz="0 1 0" />
    <limit effort="10" velocity="3" lower="-1" upper="1.35" />
    </joint>
  </robot>
