<robot name="compact_wireless_mouse">
  <material name="graphite_plastic">
    <color rgba="0.2 0.21 0.23 1" />
    </material>
  <link name="mouse_body">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <mass value="0.095" />
      <inertia ixx="0.000122898" ixy="0" ixz="0" iyy="4.50933e-05" iyz="0" izz="0.000142658" />
      </inertial>
    <visual name="outer_shell">
      <geometry>
        <mesh filename="assets/meshes/mouse_body_shell.obj" />
        </geometry>
      <material name="graphite_plastic">
        <color rgba="0.2 0.21 0.23 1" />
        </material>
      </visual>
    </link>
  </robot>
