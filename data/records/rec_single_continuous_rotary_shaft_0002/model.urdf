<robot name="belt_driven_buffing_wheel">
  <material name="machine_green">
    <color rgba="0.18 0.31 0.23 1" />
  </material>
  <material name="steel">
    <color rgba="0.68 0.7 0.73 1" />
  </material>
  <material name="buff_cloth">
    <color rgba="0.88 0.83 0.67 1" />
  </material>
  <material name="belt_black">
    <color rgba="0.09 0.09 0.1 1" />
  </material>
  <link name="motor_housing">
    <inertial>
      <origin xyz="0 0 0.09" rpy="0 0 0" />
      <mass value="18" />
      <inertia ixx="0.087" ixy="0" ixz="0" iyy="0.222" iyz="0" izz="0.2118" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/motor_housing.glb" />
      </geometry>
      <material name="machine_green" />
    </visual>
    <visual>
      <origin xyz="0.055 -0.026 0.06" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.024" length="0.018" />
      </geometry>
      <material name="steel" />
    </visual>
    <visual>
      <origin xyz="0.055 0.01702 0.0665024" rpy="0.849141 0 0" />
      <geometry>
        <box size="0.018 0.0666033 0.004" />
      </geometry>
      <material name="belt_black" />
    </visual>
    <visual>
      <origin xyz="0.055 -0.02502 0.103498" rpy="0.849141 0 0" />
      <geometry>
        <box size="0.018 0.0666033 0.004" />
      </geometry>
      <material name="belt_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.16 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.03 -0.026 0.023" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.072 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.03 -0.026 0.06" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.044" length="0.14" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0.018 0.06" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.08 0.108" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0.018 0.11" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.028" length="0.09" />
      </geometry>
    </collision>
  </link>
  <link name="spindle">
    <inertial>
      <origin xyz="0.03 0 0" rpy="0 1.5708 0" />
      <mass value="1.9" />
      <inertia ixx="0.00724723" ixy="0" ixz="0" iyy="0.00724723" iyz="0" izz="0.0063878" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/spindle_steel.glb" />
      </geometry>
      <material name="steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/buff_wheel.glb" />
      </geometry>
      <material name="buff_cloth" />
    </visual>
    <collision>
      <origin xyz="0.035 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.012" length="0.19" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.045 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.038" length="0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.055 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.08" length="0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.055 0 0.095" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.011" length="0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.045 0 0.032" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.005" length="0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="housing_to_spindle" type="continuous">
    <origin xyz="0.1 0.018 0.11" rpy="0 0 0" />
    <parent link="motor_housing" />
    <child link="spindle" />
    <axis xyz="1 0 0" />
    <limit effort="60" velocity="45" />
  </joint>
</robot>