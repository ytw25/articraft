  <joint name="base_to_link1" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="base" />
    <child link="link1" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="1.5" lower="-1.6" upper="1.6" />
  </joint>
  <joint name="link1_to_link2" type="revolute">
    <origin xyz="0.22 0 0.014" rpy="0 0 0" />
