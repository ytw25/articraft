    <child link="link4" />
    <axis xyz="0 -1 0" />
    <limit effort="5.5" velocity="2.2" lower="0" upper="1.2" />
  </joint>
  <joint name="link4_to_sensor_pod" type="fixed">
    <origin xyz="0.1 0 0" rpy="0 0 0" />
    <parent link="link4" />
    <child link="sensor_pod" />
  </joint>
</robot>