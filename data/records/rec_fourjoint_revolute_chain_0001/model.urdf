    <child link="link2" />
    <axis xyz="0 -1 0" />
    <limit effort="9" velocity="1.8" lower="0" upper="1.2" />
  </joint>
  <joint name="link2_to_link3" type="revolute">
    <origin xyz="0.18 0 0" rpy="0 0 0" />
