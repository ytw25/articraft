    <child link="link3" />
    <axis xyz="0 -1 0" />
    <limit effort="7.5" velocity="2" lower="0" upper="1.35" />
  </joint>
  <joint name="link3_to_link4" type="revolute">
    <origin xyz="0.14 0 0" rpy="0 0 0" />
