<robot name="refined_laptop">
  <material name="chassis">
    <color rgba="0.58 0.59 0.62 1" />
    </material>
  <material name="keys">
    <color rgba="0.09 0.09 0.1 1" />
    </material>
  <material name="bezel">
    <color rgba="0.05 0.05 0.06 1" />
    </material>
  <material name="screen">
    <color rgba="0.03 0.05 0.06 1" />
    </material>
  <material name="trackpad">
    <color rgba="0.25 0.26 0.28 1" />
    </material>
  <material name="polymer">
    <color rgba="0.18 0.19 0.2 1" />
    </material>
  <material name="rubber">
    <color rgba="0.1 0.1 0.11 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.008" rpy="0 0 0" />
      <mass value="1.35" />
      <inertia ixx="0.00572411" ixy="0" ixz="0" iyy="0.0115488" iyz="0" izz="0.0172153" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_shell.obj" />
        </geometry>
      <material name="chassis" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/keyboard.obj" />
        </geometry>
      <material name="keys" />
      </visual>
    <visual>
      <origin xyz="0 -0.046 0.01545" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.075 0.0008" />
        </geometry>
      <material name="trackpad" />
      </visual>
    <visual>
      <origin xyz="0 -0.086 0.00035" rpy="0 0 0" />
      <geometry>
        <box size="0.096 0.012 0.001" />
        </geometry>
      <material name="rubber" />
      </visual>
    <visual>
      <origin xyz="0 0.084 0.00035" rpy="0 0 0" />
      <geometry>
        <box size="0.096 0.012 0.001" />
        </geometry>
      <material name="rubber" />
      </visual>
    </link>
  <link name="lid">
    <inertial>
      <origin xyz="0 -0.109 0.00325" rpy="0 0 0" />
      <mass value="0.75" />
      <inertia ixx="0.00297289" ixy="0" ixz="0" iyy="0.00640264" iyz="0" izz="0.00937025" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/lid_outer.obj" />
        </geometry>
      <material name="chassis" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/lid_bezel.obj" />
        </geometry>
      <material name="bezel" />
      </visual>
    <visual>
      <origin xyz="0 -0.103 0.001" rpy="0 0 0" />
      <geometry>
        <box size="0.286 0.18 0.0008" />
        </geometry>
      <material name="screen" />
      </visual>
    <visual>
      <origin xyz="0 -0.018 0.006375" rpy="0 0 0" />
      <geometry>
        <box size="0.212 0.0075 0.00025" />
        </geometry>
      <material name="polymer" />
      </visual>
    </link>
  <joint name="base_to_lid" type="revolute">
    <origin xyz="0 0.106 0.0182" rpy="0 0 0" />
    <parent link="base" />
    <child link="lid" />
    <axis xyz="-1 0 0" />
    <limit effort="4" velocity="2.5" lower="0" upper="1.9" />
    </joint>
  </robot>
