<robot name="coaxial_rotary_stack">
  <material name="base_steel">
    <color rgba="0.58 0.6 0.63 1" />
    </material>
  <material name="outer_anodized">
    <color rgba="0.3 0.34 0.4 1" />
    </material>
  <material name="middle_anodized">
    <color rgba="0.42 0.46 0.52 1" />
    </material>
  <material name="inner_rotor">
    <color rgba="0.74 0.48 0.2 1" />
    </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.013" rpy="0 0 0" />
      <mass value="5.8" />
      <inertia ixx="0.0215446" ixy="0" ixz="0" iyy="0.0215446" iyz="0" izz="0.0383525" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base.obj" />
        </geometry>
      <material name="base_steel" />
      </visual>
    </link>
  <link name="outer_stage">
    <inertial>
      <origin xyz="0.056 0 0.039" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.00815833" ixy="0" ixz="0" iyy="0.0171783" iyz="0" izz="0.0231059" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/outer_stage.obj" />
        </geometry>
      <material name="outer_anodized" />
      </visual>
    </link>
  <link name="middle_stage">
    <inertial>
      <origin xyz="0 0 0.0315" rpy="0 0 0" />
      <mass value="1.3" />
      <inertia ixx="0.00211477" ixy="0" ixz="0" iyy="0.00211477" iyz="0" izz="0.0033696" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/middle_stage.obj" />
        </geometry>
      <material name="middle_anodized" />
      </visual>
    </link>
  <link name="inner_stage">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <mass value="0.75" />
      <inertia ixx="0.000454688" ixy="0" ixz="0" iyy="0.000454688" iyz="0" izz="0.000459375" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/inner_stage.obj" />
        </geometry>
      <material name="inner_rotor" />
      </visual>
    </link>
  <joint name="base_to_outer" type="revolute">
    <parent link="base" />
    <child link="outer_stage" />
    <axis xyz="0 0 1" />
    <limit effort="24" velocity="2.4" lower="0" upper="2.4" />
    </joint>
  <joint name="outer_to_middle" type="revolute">
    <origin xyz="0 0 0.078" rpy="0 0 0" />
    <parent link="outer_stage" />
    <child link="middle_stage" />
    <axis xyz="0 0 1" />
    <limit effort="16" velocity="2.8" lower="-1.8" upper="1.8" />
    </joint>
  <joint name="middle_to_inner" type="revolute">
    <origin xyz="0 0 0.063" rpy="0 0 0" />
    <parent link="middle_stage" />
    <child link="inner_stage" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="3.2" lower="-1.2" upper="1.2" />
    </joint>
  </robot>
