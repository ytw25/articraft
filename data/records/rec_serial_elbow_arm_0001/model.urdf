<robot name="industrial_pick_and_place_arm">
  <material name="graphite">
    <color rgba="0.22 0.23 0.25 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.92 0.42 0.08 1" />
  </material>
  <material name="tool_black">
    <color rgba="0.08 0.08 0.09 1" />
  </material>
  <link name="pedestal">
    <inertial>
      <origin xyz="0 0 0.19" rpy="0 0 0" />
      <mass value="18" />
      <inertia ixx="0.303" ixy="0" ixz="0" iyy="0.3702" iyz="0" izz="0.24" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pedestal.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.32 0.24 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.17" rpy="0 0 0" />
      <geometry>
        <box size="0.11 0.14 0.26" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.07 0.065 0.32" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.02 0.12" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.07 -0.065 0.32" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.02 0.12" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.07 0 0.32" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.032" length="0.03" />
      </geometry>
    </collision>
  </link>
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.22 0 0.02" rpy="0 0 0" />
      <mass value="4.8" />
      <inertia ixx="0.00976" ixy="0" ixz="0" iyy="0.0904" iyz="0" izz="0.08864" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/upper_arm.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <origin xyz="0.22 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.37 0.06 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.46 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.024" length="0.03" />
      </geometry>
    </collision>
  </link>
  <link name="forearm">
    <inertial>
      <origin xyz="0.15 0 0" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.00331833" ixy="0" ixz="0" iyy="0.0194517" iyz="0" izz="0.0191033" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm.glb" />
      </geometry>
      <material name="tool_black" />
    </visual>
    <collision>
      <origin xyz="0.13 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.23 0.045 0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.275 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.085 0.075" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.038" length="0.075" />
      </geometry>
    </collision>
  </link>
  <joint name="pedestal_to_upper_arm" type="revolute">
    <origin xyz="0.07 0 0.32" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1.6" lower="-0.2" upper="1.1" />
  </joint>
  <joint name="upper_arm_to_forearm" type="revolute">
    <origin xyz="0.46 0 0" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="28" velocity="1.9" lower="0" upper="1.55" />
  </joint>
</robot>