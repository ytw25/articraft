<robot name="folding_inspection_boom">
  <material name="graphite">
    <color rgba="0.24 0.26 0.29 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.95 0.48 0.1 1" />
  </material>
  <material name="blackened_steel">
    <color rgba="0.18 0.18 0.2 1" />
  </material>
  <material name="sensor_glass">
    <color rgba="0.2 0.42 0.56 0.45" />
  </material>
  <link name="base_mount">
    <inertial>
      <origin xyz="0 0 0.09" rpy="0 0 0" />
      <mass value="8" />
      <inertia ixx="0.0432" ixy="0" ixz="0" iyy="0.06" iyz="0" izz="0.06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_mount.glb" />
      </geometry>
      <material name="graphite" />
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.18 0.02" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.12 0.1" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.024 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.014 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.024 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.014 0.07" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.055 0 0.1" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.018" />
      </geometry>
    </collision>
  </link>
  <link name="primary_boom">
    <inertial>
      <origin xyz="0.19 0 0" rpy="0 0 0" />
      <mass value="2.3" />
      <inertia ixx="0.00116917" ixy="0" ixz="0" iyy="0.0311458" iyz="0" izz="0.0313567" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/primary_boom.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.03 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.2 0 0.021" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.06 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.2 0 -0.021" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.06 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.2 0.025 0" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.01 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.2 -0.025 0" rpy="0 0 0" />
      <geometry>
        <box size="0.34 0.01 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.372 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.06 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.05 0 -0.024" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.045 0.014" />
      </geometry>
    </collision>
  </link>
  <link name="telescoping_stage">
    <inertial>
      <origin xyz="0.21 0 0" rpy="0 0 0" />
      <mass value="1.4" />
      <inertia ixx="0.000373333" ixy="0" ixz="0" iyy="0.0207667" iyz="0" izz="0.0207667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/telescoping_stage.glb" />
      </geometry>
      <material name="blackened_steel" />
    </visual>
    <collision>
      <origin xyz="0.03 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.038 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.22 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.36 0.034 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.39 0.023 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.012 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.39 -0.023 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.012 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.382 0 0.027" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.028 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.382 0 -0.027" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.028 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="inspection_head">
    <inertial>
      <origin xyz="0.06 0 -0.01" rpy="0 0 0" />
      <mass value="0.7" />
      <inertia ixx="0.000303333" ixy="0" ixz="0" iyy="0.00119583" iyz="0" izz="0.00107917" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/inspection_head.glb" />
      </geometry>
      <material name="blackened_steel" />
    </visual>
    <visual>
      <origin xyz="0.126 0 -0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.022 0.022" />
      </geometry>
      <material name="sensor_glass" />
    </visual>
    <collision>
      <geometry>
        <box size="0.024 0.03 0.024" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.07 0 -0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.038 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.103 0 -0.012" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.028 0.038" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_boom" type="revolute">
    <origin xyz="0 0 0.14" rpy="0 0 0" />
    <parent link="base_mount" />
    <child link="primary_boom" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1.2" lower="0" upper="1.05" />
  </joint>
  <joint name="boom_to_stage" type="prismatic">
    <origin xyz="0.03 0 0" rpy="0 0 0" />
    <parent link="primary_boom" />
    <child link="telescoping_stage" />
    <axis xyz="1 0 0" />
    <limit effort="35" velocity="0.3" lower="0" upper="0.32" />
  </joint>
  <joint name="stage_to_head" type="revolute">
    <origin xyz="0.39 0 0" rpy="0 0 0" />
    <parent link="telescoping_stage" />
    <child link="inspection_head" />
    <axis xyz="0 -1 0" />
    <limit effort="10" velocity="2" lower="-0.9" upper="0.65" />
  </joint>
</robot>