<robot name="wall_mounted_cabinet">
  <material name="carcass_finish">
    <color rgba="0.93 0.94 0.95 1" />
  </material>
  <material name="door_finish">
    <color rgba="0.9 0.91 0.92 1" />
  </material>
  <material name="handle_finish">
    <color rgba="0.1 0.1 0.11 1" />
  </material>
  <link name="cabinet_body">
    <inertial>
      <mass value="8.5" />
      <inertia ixx="0.408" ixy="0" ixz="0" iyy="0.639483" iyz="0" izz="0.313083" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/cabinet_body.glb" />
      </geometry>
      <material name="carcass_finish">
        <color rgba="0.93 0.94 0.95 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.114 0" rpy="0 0 0" />
      <geometry>
        <box size="0.62 0.012 0.72" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.301 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.24 0.72" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.301 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.24 0.72" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.351" rpy="0 0 0" />
      <geometry>
        <box size="0.62 0.24 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.351" rpy="0 0 0" />
      <geometry>
        <box size="0.62 0.24 0.018" />
      </geometry>
    </collision>
  </link>
  <link name="door">
    <inertial>
      <origin xyz="0.312 0.01 0" rpy="0 0 0" />
      <mass value="2.6" />
      <inertia ixx="0.113658" ixy="0" ixz="0" iyy="0.197936" iyz="0" izz="0.0844515" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/cabinet_door_panel.glb" />
      </geometry>
      <material name="door_finish">
        <color rgba="0.9 0.91 0.92 1" />
      </material>
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/cabinet_door_handle.glb" />
      </geometry>
      <material name="handle_finish">
        <color rgba="0.1 0.1 0.11 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.312 0.01 0" rpy="0 0 0" />
      <geometry>
        <box size="0.624 0.02 0.724" />
      </geometry>
    </collision>
  </link>
  <joint name="body_to_door" type="revolute">
    <origin xyz="-0.312 0.1215 0" rpy="0 0 0" />
    <parent link="cabinet_body" />
    <child link="door" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1.5" lower="0" upper="1.85" />
  </joint>
</robot>