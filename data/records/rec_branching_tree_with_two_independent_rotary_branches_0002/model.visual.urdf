<robot name="mechanical_y_tree">
  <material name="frame_dark">
    <color rgba="0.22 0.24 0.27 1" />
    </material>
  <material name="branch_green">
    <color rgba="0.31 0.54 0.36 1" />
    </material>
  <link name="trunk">
    <inertial>
      <origin xyz="0 0 0.135" rpy="0 0 0" />
      <mass value="1.3" />
      <inertia ixx="0.0082875" ixy="0" ixz="0" iyy="0.0110283" iyz="0" izz="0.00352083" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/trunk.obj" />
        </geometry>
      <material name="frame_dark" />
      </visual>
    </link>
  <link name="left_branch">
    <inertial>
      <origin xyz="-0.079 0 0.11" rpy="0 0 0" />
      <mass value="0.32" />
      <inertia ixx="0.000906667" ixy="0" ixz="0" iyy="0.00233667" iyz="0" izz="0.00151533" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/left_branch.obj" />
        </geometry>
      <material name="branch_green" />
      </visual>
    </link>
  <link name="right_branch">
    <inertial>
      <origin xyz="0.079 0 0.11" rpy="0 0 0" />
      <mass value="0.32" />
      <inertia ixx="0.000906667" ixy="0" ixz="0" iyy="0.00233667" iyz="0" izz="0.00151533" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/right_branch.obj" />
        </geometry>
      <material name="branch_green" />
      </visual>
    </link>
  <joint name="trunk_to_left_branch" type="revolute">
    <origin xyz="-0.075 0 0.246" rpy="0 0 0" />
    <parent link="trunk" />
    <child link="left_branch" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="1.5" lower="-0.24" upper="0.24" />
    </joint>
  <joint name="trunk_to_right_branch" type="revolute">
    <origin xyz="0.075 0 0.246" rpy="0 0 0" />
    <parent link="trunk" />
    <child link="right_branch" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="1.5" lower="-0.24" upper="0.24" />
    </joint>
  </robot>
