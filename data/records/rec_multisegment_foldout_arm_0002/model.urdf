<robot name="deployable_stacked_arm">
  <material name="base_dark">
    <color rgba="0.24 0.25 0.28 1" />
  </material>
  <material name="arm_alloy">
    <color rgba="0.72 0.74 0.77 1" />
  </material>
  <material name="sensor_black">
    <color rgba="0.1 0.11 0.13 1" />
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <mass value="1.8" />
      <inertia ixx="0.00246" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00246" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/deployable_base.glb" />
      </geometry>
      <material name="base_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.024" rpy="0 0 0" />
      <geometry>
        <box size="0.12 0.09 0.048" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.064" rpy="0 0 0" />
      <geometry>
        <box size="0.064 0.05 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.092" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.05 0.024" />
      </geometry>
    </collision>
  </link>
  <link name="shoulder_link">
    <inertial>
      <origin xyz="0 0 0.085" rpy="0 0 0" />
      <mass value="0.48" />
      <inertia ixx="0.00104336" ixy="0" ixz="0" iyy="0.00106496" iyz="0" izz="6.032e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/shoulder_link.glb" />
      </geometry>
      <material name="arm_alloy" />
    </visual>
    <collision>
      <origin xyz="0 0 0.085" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.022 0.144" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.022 0.016" />
      </geometry>
    </collision>
  </link>
  <link name="forearm_link">
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0" />
      <mass value="0.38" />
      <inertia ixx="0.000635993" ixy="0" ixz="0" iyy="0.000653093" iyz="0" izz="4.77533e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/forearm_link.glb" />
      </geometry>
      <material name="arm_alloy" />
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.022 0.124" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.022 0.016" />
      </geometry>
    </collision>
  </link>
  <link name="wrist_link">
    <inertial>
      <origin xyz="0 0 0.0625" rpy="0 0 0" />
      <mass value="0.29" />
      <inertia ixx="0.000331301" ixy="0" ixz="0" iyy="0.000344351" iyz="0" izz="3.64433e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/wrist_link.glb" />
      </geometry>
      <material name="arm_alloy" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0625" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.022 0.099" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.022 0.016" />
      </geometry>
    </collision>
  </link>
  <link name="tool_head">
    <inertial>
      <origin xyz="0 0 0.028" rpy="0 0 0" />
      <mass value="0.14" />
      <inertia ixx="4.20467e-05" ixy="0" ixz="0" iyy="5.84267e-05" iyz="0" izz="3.738e-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/tool_head.glb" />
      </geometry>
      <material name="sensor_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.018 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.029" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.028 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.051" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.02 0.014" />
      </geometry>
    </collision>
  </link>
  <joint name="shoulder_hinge" type="revolute">
    <origin xyz="0 0 0.116" rpy="0 0 0" />
    <parent link="base" />
    <child link="shoulder_link" />
    <axis xyz="0 1 0" />
    <limit effort="24" velocity="1.8" lower="0" upper="1.3" />
  </joint>
  <joint name="elbow_hinge" type="revolute">
    <origin xyz="0 0 0.17" rpy="0 0 0" />
    <parent link="shoulder_link" />
    <child link="forearm_link" />
    <axis xyz="0 1 0" />
    <limit effort="18" velocity="2" lower="0" upper="1.7" />
  </joint>
  <joint name="wrist_hinge" type="revolute">
    <origin xyz="0 0 0.15" rpy="0 0 0" />
    <parent link="forearm_link" />
    <child link="wrist_link" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="2.4" lower="0" upper="1.55" />
  </joint>
  <joint name="wrist_to_tool" type="fixed">
    <origin xyz="0 0 0.125" rpy="0 0 0" />
    <parent link="wrist_link" />
    <child link="tool_head" />
  </joint>
</robot>