<robot name="rotary_lift_module">
  <material name="base_paint">
    <color rgba="0.26 0.29 0.31 1" />
  </material>
  <material name="machined_steel">
    <color rgba="0.76 0.78 0.8 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.92 0.46 0.12 1" />
  </material>
  <link name="base_frame">
    <inertial>
      <mass value="12" />
      <inertia ixx="0.0625" ixy="0" ixz="0" iyy="0.0949" iyz="0" izz="0.1476" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_frame.glb" />
      </geometry>
      <material name="base_paint" />
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.24 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.029" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.055" length="0.008" />
      </geometry>
    </collision>
  </link>
  <link name="rotary_head">
    <inertial>
      <origin xyz="0.025 0 0.17" rpy="0 0 0" />
      <mass value="6.5" />
      <inertia ixx="0.0801667" ixy="0" ixz="0" iyy="0.0842833" iyz="0" izz="0.0392167" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/rotary_head.glb" />
      </geometry>
      <material name="machined_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.09" length="0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.03 0 0.168" rpy="0 0 0" />
      <geometry>
        <box size="0.082 0.072 0.3" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.069 0 0.17" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.034 0.24" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0.045 0 0.01" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.00366667" ixy="0" ixz="0" iyy="0.00366667" iyz="0" izz="0.00366667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <collision>
      <origin xyz="0.005 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.038 0.06" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.036 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.088 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.043 0 0.047" rpy="0 0 0" />
      <geometry>
        <box size="0.086 0.066 0.012" />
      </geometry>
    </collision>
  </link>
  <joint name="base_yaw" type="revolute">
    <origin xyz="0 0 0.034" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="rotary_head" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="1.5" lower="-2.5" upper="2.5" />
  </joint>
  <joint name="column_lift" type="prismatic">
    <origin xyz="0.076 0 0.145" rpy="0 0 0" />
    <parent link="rotary_head" />
    <child link="carriage" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.25" lower="0" upper="0.18" />
  </joint>
</robot>