<robot name="two_axis_wrist_module">
  <material name="housing_gray">
    <color rgba="0.56 0.58 0.62 1" />
  </material>
  <material name="plate_blue">
    <color rgba="0.25 0.4 0.7 1" />
  </material>
  <material name="rotor_dark">
    <color rgba="0.18 0.2 0.24 1" />
  </material>
  <link name="base_housing">
    <inertial>
      <origin xyz="0 0 -0.022" rpy="0 0 0" />
      <mass value="0.72" />
      <inertia ixx="0.00027096" ixy="0" ixz="0" iyy="0.00032664" iyz="0" izz="0.0004056" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_housing.glb" />
      </geometry>
      <material name="housing_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0" />
      <geometry>
        <box size="0.058 0.05 0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.023 -0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.012 0.026" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.023 -0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.028 0.012 0.026" />
      </geometry>
    </collision>
  </link>
  <link name="pitch_link">
    <inertial>
      <origin xyz="0 0 0.048" rpy="0 0 0" />
      <mass value="0.38" />
      <inertia ixx="0.000307167" ixy="0" ixz="0" iyy="0.00032946" iyz="0" izz="0.000123627" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pitch_link.glb" />
      </geometry>
      <material name="plate_blue" />
    </visual>
    <collision>
      <origin xyz="0 0 0.047" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.012 0.064" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0085" length="0.104" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.078" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.024" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.015 0 0.078" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.028 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.015 0 0.078" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.028 0.016" />
      </geometry>
    </collision>
  </link>
  <link name="roll_stage">
    <inertial>
      <origin xyz="0.022 0 0.03" rpy="0 0 0" />
      <mass value="0.27" />
      <inertia ixx="9e-05" ixy="0" ixz="0" iyy="0.00013653" iyz="0" izz="0.00010485" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/roll_stage.glb" />
      </geometry>
      <material name="rotor_dark" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.048" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.022" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0105" length="0.04" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.028 0 0.036" rpy="0 0 0" />
      <geometry>
        <box size="0.056 0.034 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.052 0 0.05" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="pitch_hinge" type="revolute">
    <parent link="base_housing" />
    <child link="pitch_link" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="4" lower="-1.1" upper="1.1" />
  </joint>
  <joint name="roll_joint" type="continuous">
    <origin xyz="0 0 0.078" rpy="0 0 0" />
    <parent link="pitch_link" />
    <child link="roll_stage" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="10" />
  </joint>
</robot>