<robot name="ceiling_fan">
  <material name="brushed_nickel">
    <color rgba="0.76 0.77 0.79 1" />
    </material>
  <material name="satin_black">
    <color rgba="0.12 0.12 0.13 1" />
    </material>
  <material name="dark_walnut">
    <color rgba="0.35 0.22 0.13 1" />
    </material>
  <link name="mount">
    <inertial>
      <origin xyz="0 0 -0.175" rpy="0 0 0" />
      <mass value="2.8" />
      <inertia ixx="0.0320133" ixy="0" ixz="0" iyy="0.0320133" iyz="0" izz="0.00686" />
      </inertial>
    <visual name="canopy">
      <geometry>
        <mesh filename="assets/meshes/ceiling_fan_canopy.obj" />
        </geometry>
      <material name="brushed_nickel">
        <color rgba="0.76 0.77 0.79 1" />
        </material>
      </visual>
    <visual name="ceiling_gasket">
      <origin xyz="0 0 -0.002" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.076" length="0.004" />
        </geometry>
      <material name="satin_black">
        <color rgba="0.12 0.12 0.13 1" />
        </material>
      </visual>
    <visual name="downrod_collar">
      <origin xyz="0 0 -0.063" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.02" length="0.016" />
        </geometry>
      <material name="satin_black">
        <color rgba="0.12 0.12 0.13 1" />
        </material>
      </visual>
    <visual name="downrod">
      <origin xyz="0 0 -0.145" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.011" length="0.18" />
        </geometry>
      <material name="brushed_nickel">
        <color rgba="0.76 0.77 0.79 1" />
        </material>
      </visual>
    <visual name="motor_coupler">
      <origin xyz="0 0 -0.265" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.018" length="0.06" />
        </geometry>
      <material name="brushed_nickel">
        <color rgba="0.76 0.77 0.79 1" />
        </material>
      </visual>
    <visual name="hanger_yoke">
      <origin xyz="0 0 -0.321" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.028" length="0.052" />
        </geometry>
      <material name="brushed_nickel">
        <color rgba="0.76 0.77 0.79 1" />
        </material>
      </visual>
    </link>
  <link name="rotor">
    <inertial>
      <origin xyz="0 0 -0.1" rpy="0 0 0" />
      <mass value="6.6" />
      <inertia ixx="0.67914" ixy="0" ixz="0" iyy="0.67914" iyz="0" izz="1.30977" />
      </inertial>
    <visual name="rotor_collar">
      <origin xyz="0 0 -0.008" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.03" length="0.016" />
        </geometry>
      <material name="satin_black">
        <color rgba="0.12 0.12 0.13 1" />
        </material>
      </visual>
    <visual name="motor_housing">
      <geometry>
        <mesh filename="assets/meshes/ceiling_fan_rotor_shell.obj" />
        </geometry>
      <material name="brushed_nickel">
        <color rgba="0.76 0.77 0.79 1" />
        </material>
      </visual>
    <visual name="blade_arms">
      <geometry>
        <mesh filename="assets/meshes/ceiling_fan_blade_arms.obj" />
        </geometry>
      <material name="satin_black">
        <color rgba="0.12 0.12 0.13 1" />
        </material>
      </visual>
    <visual name="blades">
      <geometry>
        <mesh filename="assets/meshes/ceiling_fan_blades.obj" />
        </geometry>
      <material name="dark_walnut">
        <color rgba="0.35 0.22 0.13 1" />
        </material>
      </visual>
    </link>
  <joint name="mount_to_rotor_spin" type="continuous">
    <origin xyz="0 0 -0.35" rpy="0 0 0" />
    <parent link="mount" />
    <child link="rotor" />
    <axis xyz="0 0 -1" />
    <limit effort="5" velocity="20" />
    </joint>
  </robot>
