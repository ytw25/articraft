<robot name="sliding_monitor_mount">
  <material name="anodized_aluminum">
    <color rgba="0.73 0.75 0.79 1" />
  </material>
  <material name="powder_coat">
    <color rgba="0.18 0.19 0.21 1" />
  </material>
  <material name="display_black">
    <color rgba="0.09 0.09 0.1 1" />
  </material>
  <link name="rail">
    <inertial>
      <mass value="1.6" />
      <inertia ixx="0.000546667" ixy="0" ixz="0" iyy="0.0238533" iyz="0" izz="0.0237333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/rail.glb" />
      </geometry>
      <material name="anodized_aluminum" />
    </visual>
    <collision>
      <geometry>
        <box size="0.42 0.04 0.05" />
      </geometry>
    </collision>
  </link>
  <link name="carriage">
    <inertial>
      <origin xyz="0 0.024 0.015" rpy="0 0 0" />
      <mass value="0.7" />
      <inertia ixx="0.000526633" ixy="0" ixz="0" iyy="0.000864733" iyz="0" izz="0.0006069" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/carriage.glb" />
      </geometry>
      <material name="powder_coat" />
    </visual>
    <collision>
      <origin xyz="0 0.012 0" rpy="0 0 0" />
      <geometry>
        <box size="0.09 0.024 0.032" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.03 0.016" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.012 0.072" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.034 0.046" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.016 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="display_plate">
    <inertial>
      <origin xyz="0 0.006 -0.09" rpy="0 0 0" />
      <mass value="1.8" />
      <inertia ixx="0.0048816" ixy="0" ixz="0" iyy="0.015795" iyz="0" izz="0.0109566" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/display_plate.glb" />
      </geometry>
      <material name="display_black" />
    </visual>
    <collision>
      <origin xyz="0 0.006 -0.09" rpy="0 0 0" />
      <geometry>
        <box size="0.27 0.012 0.18" />
      </geometry>
    </collision>
  </link>
  <joint name="rail_to_carriage" type="prismatic">
    <origin xyz="0 0.023 0" rpy="0 0 0" />
    <parent link="rail" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.25" lower="-0.14" upper="0.14" />
  </joint>
  <joint name="carriage_to_display" type="revolute">
    <origin xyz="0 0.045 0.048" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="display_plate" />
    <axis xyz="1 0 0" />
    <limit effort="30" velocity="1.2" lower="0" upper="0.55" />
  </joint>
</robot>