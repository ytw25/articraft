  <link name="z_slide">
    <inertial>
      <origin xyz="0 0 -0.06" rpy="0 0 0" />
      <mass value="1.4" />
      <inertia ixx="0.00415333" ixy="0" ixz="0" iyy="0.00597333" iyz="0" izz="0.00415333" />
