  </link>
  <joint name="base_to_gantry" type="prismatic">
    <origin xyz="-0.305 0 0.1" rpy="0 0 0" />
    <parent link="base" />
    <child link="gantry" />
    <axis xyz="0 1 0" />
    <limit effort="120" velocity="0.6" lower="-0.16" upper="0.16" />
  </joint>
  <joint name="gantry_to_x_carriage" type="prismatic">
    <origin xyz="0.305 -0.035 0.305" rpy="0 0 0" />
    <parent link="gantry" />
    <child link="x_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="90" velocity="0.8" lower="-0.18" upper="0.18" />
  </joint>
  <joint name="x_carriage_to_z_slide" type="prismatic">
    <origin xyz="0 0 -0.09" rpy="0 0 0" />
    <parent link="x_carriage" />
    <child link="z_slide" />
    <axis xyz="0 0 -1" />
    <limit effort="70" velocity="0.35" lower="0" upper="0.06" />
  </joint>
</robot>