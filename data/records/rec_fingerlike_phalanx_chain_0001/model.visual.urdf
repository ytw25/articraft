<robot name="mechanical_finger_chain">
  <material name="mount_grey">
    <color rgba="0.28 0.3 0.33 1" />
    </material>
  <material name="proximal_blue">
    <color rgba="0.34 0.42 0.56 1" />
    </material>
  <material name="middle_steel">
    <color rgba="0.58 0.6 0.65 1" />
    </material>
  <material name="distal_brass">
    <color rgba="0.72 0.58 0.3 1" />
    </material>
  <link name="base_mount">
    <inertial>
      <origin xyz="-0.019 0 0" rpy="0 0 0" />
      <mass value="0.32" />
      <inertia ixx="2.15467e-05" ixy="0" ixz="0" iyy="3.264e-05" iyz="0" izz="3.69067e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/base_mount.obj" />
        </geometry>
      <material name="mount_grey" />
      </visual>
    </link>
  <link name="proximal">
    <inertial>
      <origin xyz="0.02714 0 0" rpy="0 0 0" />
      <mass value="0.14" />
      <inertia ixx="2.14527e-06" ixy="0" ixz="0" iyy="1.84566e-05" iyz="0" izz="1.78803e-05" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/proximal.obj" />
        </geometry>
      <material name="proximal_blue" />
      </visual>
    </link>
  <link name="middle">
    <inertial>
      <origin xyz="0.02219 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="1.18395e-06" ixy="0" ixz="0" iyy="7.44195e-06" iyz="0" izz="7.16574e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/middle.obj" />
        </geometry>
      <material name="middle_steel" />
      </visual>
    </link>
  <link name="distal">
    <inertial>
      <origin xyz="0.0182 0 0" rpy="0 0 0" />
      <mass value="0.07" />
      <inertia ixx="5.84792e-07" ixy="0" ixz="0" iyy="3.27279e-06" iyz="0" izz="3.16587e-06" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/distal.obj" />
        </geometry>
      <material name="distal_brass" />
      </visual>
    </link>
  <joint name="base_to_proximal" type="revolute">
    <parent link="base_mount" />
    <child link="proximal" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="2" lower="0" upper="1.2" />
    </joint>
  <joint name="proximal_to_middle" type="revolute">
    <origin xyz="0.058 0 0" rpy="0 0 0" />
    <parent link="proximal" />
    <child link="middle" />
    <axis xyz="0 1 0" />
    <limit effort="3.2" velocity="2.5" lower="0" upper="1.35" />
    </joint>
  <joint name="middle_to_distal" type="revolute">
    <origin xyz="0.043 0 0" rpy="0 0 0" />
    <parent link="middle" />
    <child link="distal" />
    <axis xyz="0 1 0" />
    <limit effort="2.3" velocity="3" lower="0" upper="1.1" />
    </joint>
  </robot>
