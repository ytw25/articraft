  <joint name="base_to_proximal" type="revolute">
    <parent link="base_mount" />
    <child link="proximal" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="2" lower="0" upper="1.2" />
  </joint>
  <joint name="proximal_to_middle" type="revolute">
    <origin xyz="0.058 0 0" rpy="0 0 0" />
    <parent link="proximal" />
    <child link="middle" />
    <axis xyz="0 1 0" />
    <limit effort="3.2" velocity="2.5" lower="0" upper="1.35" />
  </joint>
  <joint name="middle_to_distal" type="revolute">
    <origin xyz="0.043 0 0" rpy="0 0 0" />
    <parent link="middle" />
    <child link="distal" />
    <axis xyz="0 1 0" />
    <limit effort="2.3" velocity="3" lower="0" upper="1.1" />
  </joint>
