  <link name="distal">
    <inertial>
      <origin xyz="0.0182 0 0" rpy="0 0 0" />
      <mass value="0.07" />
      <inertia ixx="5.84792e-07" ixy="0" ixz="0" iyy="3.27279e-06" iyz="0" izz="3.16587e-06" />
