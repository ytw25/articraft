<robot name="precision_xy_stage">
  <material name="anodized_black">
    <color rgba="0.16 0.17 0.19 1" />
  </material>
  <material name="ground_steel">
    <color rgba="0.72 0.74 0.78 1" />
  </material>
  <material name="machined_gray">
    <color rgba="0.6 0.62 0.66 1" />
  </material>
  <material name="plate_blue">
    <color rgba="0.41 0.47 0.6 1" />
  </material>
  <link name="base">
    <inertial>
      <mass value="4.2" />
      <inertia ixx="0.0115094" ixy="0" ixz="0" iyy="0.0276094" iyz="0" izz="0.03878" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stage_base_body.glb" />
      </geometry>
      <material name="anodized_black" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/stage_x_rails.glb" />
      </geometry>
      <material name="ground_steel" />
    </visual>
    <collision>
      <geometry>
        <box size="0.28 0.18 0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.055 0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.018 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.018 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="x_stage">
    <inertial>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00293987" ixy="0" ixz="0" iyy="0.00221987" iyz="0" izz="0.00488667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stage_x_carriage.glb" />
      </geometry>
      <material name="machined_gray" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/stage_y_rails.glb" />
      </geometry>
      <material name="ground_steel" />
    </visual>
    <collision>
      <origin xyz="0 0.055 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.026 0.009" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.055 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.026 0.009" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <geometry>
        <box size="0.125 0.145 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.022" rpy="0 0 0" />
      <geometry>
        <box size="0.102 0.092 0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.032 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.13 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.032 0 0.02" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.13 0.008" />
      </geometry>
    </collision>
  </link>
  <link name="y_stage">
    <inertial>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <mass value="0.9" />
      <inertia ixx="0.0009915" ixy="0" ixz="0" iyy="0.0015207" iyz="0" izz="0.0024108" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/stage_top_stage.glb" />
      </geometry>
      <material name="plate_blue" />
    </visual>
    <collision>
      <origin xyz="0.032 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.024 0.055 0.007" />
