      <geometry>
        <box size="0.09 0.068 0.008" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_x" type="prismatic">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="base" />
    <child link="x_stage" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.25" lower="-0.06" upper="0.06" />
  </joint>
  <joint name="x_to_y" type="prismatic">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="x_stage" />
    <child link="y_stage" />
    <axis xyz="0 1 0" />
    <limit effort="90" velocity="0.25" lower="-0.035" upper="0.035" />
  </joint>
</robot>