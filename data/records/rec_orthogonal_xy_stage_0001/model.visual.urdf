<robot name="precision_xy_stage">
  <material name="anodized_black">
    <color rgba="0.16 0.17 0.19 1" />
    </material>
  <material name="ground_steel">
    <color rgba="0.72 0.74 0.78 1" />
    </material>
  <material name="machined_gray">
    <color rgba="0.6 0.62 0.66 1" />
    </material>
  <material name="plate_blue">
    <color rgba="0.41 0.47 0.6 1" />
    </material>
  <link name="base">
    <inertial>
      <mass value="4.2" />
      <inertia ixx="0.0115094" ixy="0" ixz="0" iyy="0.0276094" iyz="0" izz="0.03878" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage_base_body.obj" />
        </geometry>
      <material name="anodized_black" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage_x_rails.obj" />
        </geometry>
      <material name="ground_steel" />
      </visual>
    </link>
  <link name="x_stage">
    <inertial>
      <origin xyz="0 0 0.014" rpy="0 0 0" />
      <mass value="1.6" />
      <inertia ixx="0.00293987" ixy="0" ixz="0" iyy="0.00221987" iyz="0" izz="0.00488667" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage_x_carriage.obj" />
        </geometry>
      <material name="machined_gray" />
      </visual>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage_y_rails.obj" />
        </geometry>
      <material name="ground_steel" />
      </visual>
    </link>
  <link name="y_stage">
    <inertial>
      <origin xyz="0 0 0.011" rpy="0 0 0" />
      <mass value="0.9" />
      <inertia ixx="0.0009915" ixy="0" ixz="0" iyy="0.0015207" iyz="0" izz="0.0024108" />
      </inertial>
    <visual>
      <geometry>
        <mesh filename="assets/meshes/stage_top_stage.obj" />
        </geometry>
      <material name="plate_blue" />
      </visual>
    </link>
  <joint name="base_to_x" type="prismatic">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="base" />
    <child link="x_stage" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.25" lower="-0.06" upper="0.06" />
    </joint>
  <joint name="x_to_y" type="prismatic">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="x_stage" />
    <child link="y_stage" />
    <axis xyz="0 1 0" />
    <limit effort="90" velocity="0.25" lower="-0.035" upper="0.035" />
    </joint>
  </robot>
