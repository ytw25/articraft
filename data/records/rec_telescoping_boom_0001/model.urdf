<robot name="telescoping_boom">
  <material name="boom_yellow">
    <color rgba="0.88 0.72 0.1 1" />
  </material>
  <material name="industrial_steel">
    <color rgba="0.28 0.3 0.33 1" />
  </material>
  <link name="base_bracket">
    <inertial>
      <origin xyz="-0.03 0 0.11" rpy="0 0 0" />
      <mass value="48" />
      <inertia ixx="0.656" ixy="0" ixz="0" iyy="1.04" iyz="0" izz="1.3088" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_bracket.glb" />
      </geometry>
      <material name="industrial_steel" />
    </visual>
    <collision name="base_plate">
      <origin xyz="0 0 0.015" rpy="0 0 0" />
      <geometry>
        <box size="0.46 0.34 0.03" />
      </geometry>
    </collision>
    <collision name="rear_spine">
      <origin xyz="-0.18 0 0.115" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.18 0.17" />
      </geometry>
    </collision>
    <collision name="left_cheek">
      <origin xyz="-0.06 0.11 0.12" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.03 0.18" />
      </geometry>
    </collision>
    <collision name="right_cheek">
      <origin xyz="-0.06 -0.11 0.12" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.03 0.18" />
      </geometry>
    </collision>
    <collision name="saddle">
      <origin xyz="-0.02 0 0.2" rpy="0 0 0" />
      <geometry>
        <box size="0.26 0.16 0.02" />
      </geometry>
    </collision>
  </link>
  <link name="outer_stage">
    <inertial>
      <origin xyz="0.675 0 0.07" rpy="0 0 0" />
      <mass value="18" />
      <inertia ixx="0.078" ixy="0" ixz="0" iyy="2.76315" iyz="0" izz="2.78235" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/outer_stage.glb" />
      </geometry>
      <material name="boom_yellow" />
    </visual>
    <collision name="outer_left_wall">
      <origin xyz="0.675 0.084 0.07" rpy="0 0 0" />
      <geometry>
        <box size="1.35 0.012 0.14" />
      </geometry>
    </collision>
    <collision name="outer_right_wall">
      <origin xyz="0.675 -0.084 0.07" rpy="0 0 0" />
      <geometry>
        <box size="1.35 0.012 0.14" />
      </geometry>
    </collision>
    <collision name="outer_bottom_wall">
      <origin xyz="0.675 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="1.35 0.156 0.012" />
      </geometry>
    </collision>
    <collision name="outer_top_wall">
      <origin xyz="0.675 0 0.134" rpy="0 0 0" />
      <geometry>
        <box size="1.35 0.156 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="mid_stage">
    <inertial>
      <origin xyz="0.51 0 0.054" rpy="0 0 0" />
      <mass value="12" />
      <inertia ixx="0.033568" ixy="0" ixz="0" iyy="1.05206" iyz="0" izz="1.0623" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/mid_stage.glb" />
      </geometry>
      <material name="boom_yellow" />
    </visual>
    <collision name="mid_left_wall">
      <origin xyz="0.51 0.069 0.054" rpy="0 0 0" />
      <geometry>
        <box size="1.02 0.01 0.108" />
      </geometry>
    </collision>
    <collision name="mid_right_wall">
      <origin xyz="0.51 -0.069 0.054" rpy="0 0 0" />
      <geometry>
        <box size="1.02 0.01 0.108" />
      </geometry>
    </collision>
    <collision name="mid_bottom_wall">
      <origin xyz="0.51 0 0.005" rpy="0 0 0" />
      <geometry>
        <box size="1.02 0.128 0.01" />
      </geometry>
    </collision>
    <collision name="mid_top_wall">
      <origin xyz="0.51 0 0.103" rpy="0 0 0" />
      <geometry>
        <box size="1.02 0.128 0.01" />
      </geometry>
    </collision>
  </link>
  <link name="inner_stage">
    <inertial>
      <origin xyz="0.45 0 0.049" rpy="0 0 0" />
      <mass value="7" />
      <inertia ixx="0.0167113" ixy="0" ixz="0" iyy="0.478102" iyz="0" izz="0.483609" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/inner_stage.glb" />
      </geometry>
      <material name="boom_yellow" />
    </visual>
    <collision name="inner_left_wall">
      <origin xyz="0.41 0.055 0.039" rpy="0 0 0" />
      <geometry>
        <box size="0.82 0.008 0.078" />
      </geometry>
    </collision>
    <collision name="inner_right_wall">
      <origin xyz="0.41 -0.055 0.039" rpy="0 0 0" />
      <geometry>
        <box size="0.82 0.008 0.078" />
      </geometry>
    </collision>
    <collision name="inner_bottom_wall">
      <origin xyz="0.41 0 0.004" rpy="0 0 0" />
      <geometry>
        <box size="0.82 0.102 0.008" />
      </geometry>
    </collision>
    <collision name="inner_top_wall">
      <origin xyz="0.41 0 0.074" rpy="0 0 0" />
      <geometry>
        <box size="0.82 0.102 0.008" />
      </geometry>
    </collision>
    <collision name="tip_head">
      <origin xyz="0.864 0 0.039" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.128 0.074" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_outer" type="fixed">
    <origin xyz="-0.06 0 0.211" rpy="0 0 0" />
    <parent link="base_bracket" />
    <child link="outer_stage" />
  </joint>
  <joint name="outer_to_mid" type="prismatic">
    <origin xyz="0 0 0.016" rpy="0 0 0" />
    <parent link="outer_stage" />
    <child link="mid_stage" />
    <axis xyz="1 0 0" />
    <limit effort="1200" velocity="0.3" lower="0" upper="0.62" />
  </joint>
  <joint name="mid_to_inner" type="prismatic">
    <origin xyz="0 0 0.015" rpy="0 0 0" />
    <parent link="mid_stage" />
    <child link="inner_stage" />
    <axis xyz="1 0 0" />
    <limit effort="900" velocity="0.35" lower="0" upper="0.55" />
  </joint>
</robot>