<robot name="tilt_bracket_mechanism">
  <material name="powdercoat_dark">
    <color rgba="0.18 0.19 0.21 1" />
  </material>
  <material name="anodized_aluminum">
    <color rgba="0.72 0.74 0.78 1" />
  </material>
  <link name="base_plate">
    <inertial>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <mass value="0.65" />
      <inertia ixx="0.0007878" ixy="0" ixz="0" iyy="0.00262947" iyz="0" izz="0.00340167" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/base_plate.glb" />
      </geometry>
      <material name="powdercoat_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.22 0.12 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="support_yoke">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <mass value="0.9" />
      <inertia ixx="0.00246188" ixy="0" ixz="0" iyy="0.00384" iyz="0" izz="0.00246188" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/support_yoke.glb" />
      </geometry>
      <material name="powdercoat_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.038 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.075 0 0.08" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.085 0.16" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.075 0 0.08" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.085 0.16" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.083" rpy="0 0 0" />
      <geometry>
        <box size="0.158 0.012 0.012" />
      </geometry>
    </collision>
  </link>
  <link name="payload_frame">
    <inertial>
      <origin xyz="0 0 0.009" rpy="0 0 0" />
      <mass value="0.42" />
      <inertia ixx="0.000875" ixy="0" ixz="0" iyy="0.00028854" iyz="0" izz="0.00059654" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/payload_frame.glb" />
      </geometry>
      <material name="anodized_aluminum" />
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.13 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.019" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.13 0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.057 0.018" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.016 0.058" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.057 0.018" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.016 0.058" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.032" rpy="0 0 0" />
      <geometry>
        <box size="0.012 0.086 0.012" />
      </geometry>
    </collision>
    <collision>
      <geometry>
        <box size="0.13 0.024 0.024" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_yoke" type="fixed">
    <origin xyz="0 0 0.012" rpy="0 0 0" />
    <parent link="base_plate" />
    <child link="support_yoke" />
  </joint>
  <joint name="yoke_to_payload" type="revolute">
    <origin xyz="0 0 0.083" rpy="0 0 0" />
    <parent link="support_yoke" />
    <child link="payload_frame" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="1.5" lower="-0.95" upper="0.95" />
  </joint>
</robot>