<robot name="sensor_mount_pitch_roll">
  <link name="mount_base">
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <mass value="1.1" />
      <inertia ixx="0.0020625" ixy="0" ixz="0" iyy="0.00308917" iyz="0" izz="0.00366667" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/mount_base.glb" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.066" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.12 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.024 -0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.01 0.086" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.024 -0.017" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.01 0.086" />
      </geometry>
    </collision>
  </link>
  <link name="pitch_cradle">
    <inertial>
      <mass value="0.42" />
      <inertia ixx="0.00028" ixy="0" ixz="0" iyy="0.0003115" iyz="0" izz="0.0001435" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pitch_cradle.glb" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.024 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.032 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.024 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.032 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.034" rpy="0 0 0" />
      <geometry>
        <box size="0.046 0.028 0.008" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.034" rpy="0 0 0" />
      <geometry>
        <box size="0.046 0.028 0.008" />
      </geometry>
    </collision>
    <collision>
      <geometry>
        <box size="0.064 0.064 0.018" />
      </geometry>
    </collision>
    <collision>
      <geometry>
        <box size="0.01 0.028 0.01" />
      </geometry>
    </collision>
  </link>
  <link name="sensor_head">
    <inertial>
      <origin xyz="0.012 0 0.005" rpy="0 0 0" />
      <mass value="0.34" />
      <inertia ixx="6.222e-05" ixy="0" ixz="0" iyy="0.000125573" iyz="0" izz="0.000114353" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/sensor_head.glb" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.018 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.022 0.03" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.01 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.01 0.01" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.034 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.032 0.018 0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_pitch_cradle" type="revolute">
    <parent link="mount_base" />
    <child link="pitch_cradle" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="2" lower="-0.9" upper="0.9" />
  </joint>
  <joint name="pitch_cradle_to_sensor_head" type="revolute">
    <parent link="pitch_cradle" />
    <child link="sensor_head" />
    <axis xyz="1 0 0" />
    <limit effort="4" velocity="2.5" lower="-1.3" upper="1.3" />
  </joint>
</robot>