<robot name="pan_tilt_surveillance_head">
  <material name="cast_gray">
    <color rgba="0.58 0.6 0.62 1" />
  </material>
  <material name="equipment_black">
    <color rgba="0.12 0.13 0.15 1" />
  </material>
  <link name="mount_base">
    <inertial>
      <origin xyz="0 0 0.037" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.00248893" ixy="0" ixz="0" iyy="0.00283727" iyz="0" izz="0.00331833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/mount_base.glb" />
      </geometry>
      <material name="cast_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.14 0.12 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0" />
      <geometry>
        <box size="0.088 0.072 0.046" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.068" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.032" length="0.012" />
      </geometry>
    </collision>
  </link>
  <link name="pan_fork">
    <inertial>
      <origin xyz="0.012 0 0.047" rpy="0 0 0" />
      <mass value="0.95" />
      <inertia ixx="0.000897433" ixy="0" ixz="0" iyy="0.00115678" iyz="0" izz="0.000655183" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pan_fork.glb" />
      </geometry>
      <material name="cast_gray" />
    </visual>
    <collision>
      <origin xyz="0 0 0.008" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.032" length="0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.006 0 0.039" rpy="0 0 0" />
      <geometry>
        <box size="0.056 0.042 0.046" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.042 0.022 0.067" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.008 0.038" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.042 -0.022 0.067" rpy="0 0 0" />
      <geometry>
        <box size="0.022 0.008 0.038" />
      </geometry>
    </collision>
  </link>
  <link name="sensor_head">
    <inertial>
      <origin xyz="0.07 0 0" rpy="0 0 0" />
      <mass value="0.75" />
      <inertia ixx="0.0002665" ixy="0" ixz="0" iyy="0.0010265" iyz="0" izz="0.0009805" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/sensor_head.glb" />
      </geometry>
      <material name="equipment_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.008" length="0.028" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.032 0.03" />
      </geometry>
    </collision>
  </link>
  <joint name="pan_joint" type="revolute">
    <origin xyz="0 0 0.074" rpy="0 0 0" />
    <parent link="mount_base" />
    <child link="pan_fork" />
    <axis xyz="0 0 1" />
    <limit effort="30" velocity="1.5" lower="-2.8" upper="2.8" />
  </joint>
  <joint name="tilt_joint" type="revolute">
    <origin xyz="0.042 0 0.068" rpy="0 0 0" />
    <parent link="pan_fork" />
    <child link="sensor_head" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.2" lower="-0.35" upper="0.6" />
  </joint>
</robot>