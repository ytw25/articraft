<robot name="horizontal_scanning_platform">
  <material name="frame_paint">
    <color rgba="0.34 0.36 0.39 1" />
  </material>
  <material name="machined_steel">
    <color rgba="0.73 0.74 0.76 1" />
  </material>
  <material name="safety_orange">
    <color rgba="0.93 0.46 0.15 1" />
  </material>
  <material name="sensor_black">
    <color rgba="0.1 0.11 0.12 1" />
  </material>
  <link name="mount_frame">
    <inertial>
      <origin xyz="0 0 0.0615" rpy="0 0 0" />
      <mass value="16" />
      <inertia ixx="0.0847053" ixy="0" ixz="0" iyy="0.156705" iyz="0" izz="0.201067" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/mount_frame_body.glb" />
      </geometry>
      <material name="frame_paint" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/mount_frame_race.glb" />
      </geometry>
      <material name="machined_steel" />
    </visual>
    <collision>
      <origin xyz="0 0 0.007" rpy="0 0 0" />
      <geometry>
        <box size="0.32 0.22 0.014" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.074 0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.26 0.028 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.074 0.009" rpy="0 0 0" />
      <geometry>
        <box size="0.26 0.028 0.018" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.103 0 0.053" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.18 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.103 0 0.053" rpy="0 0 0" />
      <geometry>
        <box size="0.014 0.18 0.078" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.084 0.057" rpy="0 0 0" />
      <geometry>
        <box size="0.196 0.012 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.084 0.057" rpy="0 0 0" />
      <geometry>
        <box size="0.196 0.012 0.05" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.094" rpy="0 0 0" />
      <geometry>
        <box size="0.24 0.18 0.012" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.1145" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.056" length="0.017" />
      </geometry>
    </collision>
  </link>
  <link name="scanner_platform">
    <inertial>
      <origin xyz="0.06 0 0.05" rpy="0 0 0" />
      <mass value="8.5" />
      <inertia ixx="0.0275542" ixy="0" ixz="0" iyy="0.0708333" iyz="0" izz="0.0842208" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/scanner_platform_hub.glb" />
      </geometry>
      <material name="machined_steel" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/scanner_platform_deck.glb" />
      </geometry>
      <material name="safety_orange" />
    </visual>
    <visual>
      <geometry>
        <mesh filename="meshes/scanner_platform_sensor.glb" />
      </geometry>
      <material name="sensor_black" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0045" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.068" length="0.007" />
