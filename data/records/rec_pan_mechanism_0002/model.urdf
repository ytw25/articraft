    <collision>
      <origin xyz="-0.028 0 0.042" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.08 0.024" />
      </geometry>
    </collision>
  </link>
  <joint name="frame_to_platform_pan" type="revolute">
    <origin xyz="0 0 0.124" rpy="0 0 0" />
    <parent link="mount_frame" />
    <child link="scanner_platform" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="2.5" lower="-2.6" upper="2.6" />
  </joint>
</robot>