<robot name="turntable_pedestal_elevator">
  <material name="housing_dark">
    <color rgba="0.18 0.2 0.23 1" />
  </material>
  <material name="frame_light">
    <color rgba="0.76 0.78 0.8 1" />
  </material>
  <material name="carriage_gray">
    <color rgba="0.62 0.66 0.7 1" />
  </material>
  <link name="pedestal_base">
    <inertial>
      <origin xyz="0 0 0.065" rpy="0 0 0" />
      <mass value="7.5" />
      <inertia ixx="0.0585625" ixy="0" ixz="0" iyy="0.0585625" iyz="0" izz="0.096" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/pedestal_base.glb" />
      </geometry>
      <material name="housing_dark" />
    </visual>
    <collision>
      <origin xyz="0 0 0.008" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.185" length="0.016" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.068" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.155" length="0.104" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.125" length="0.01" />
      </geometry>
    </collision>
  </link>
  <link name="turntable_stage">
    <inertial>
      <origin xyz="0 0.01 0.18" rpy="0 0 0" />
      <mass value="4.5" />
      <inertia ixx="0.054" ixy="0" ixz="0" iyy="0.0702" iyz="0" izz="0.027" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/turntable_stage.glb" />
      </geometry>
      <material name="frame_light" />
    </visual>
    <collision>
      <origin xyz="0 0 0.012" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.115" length="0.022" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.005 0.183" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.035 0.32" />
      </geometry>
    </collision>
  </link>
  <link name="top_carriage">
    <inertial>
      <origin xyz="0 0.05 0.04" rpy="0 0 0" />
      <mass value="2.2" />
      <inertia ixx="0.00634333" ixy="0" ixz="0" iyy="0.010065" iyz="0" izz="0.00815833" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/top_carriage.glb" />
      </geometry>
      <material name="carriage_gray" />
    </visual>
    <collision>
      <origin xyz="0 0.026 0" rpy="0 0 0" />
      <geometry>
        <box size="0.132 0.016 0.13" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="-0.045 0.015 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.03 0.08" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.045 0.015 0" rpy="0 0 0" />
      <geometry>
        <box size="0.036 0.03 0.08" />
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0.065 0.085" rpy="0 0 0" />
      <geometry>
        <box size="0.18 0.09 0.018" />
      </geometry>
    </collision>
  </link>
  <joint name="pedestal_yaw" type="revolute">
    <origin xyz="0 0 0.13" rpy="0 0 0" />
    <parent link="pedestal_base" />
    <child link="turntable_stage" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="1.5" lower="-1.5708" upper="1.5708" />
  </joint>
  <joint name="elevator_z" type="prismatic">
    <origin xyz="0 0.029 0.12" rpy="0 0 0" />
    <parent link="turntable_stage" />
    <child link="top_carriage" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="0.25" lower="0" upper="0.16" />
  </joint>
</robot>