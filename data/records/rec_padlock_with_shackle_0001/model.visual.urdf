<robot name="security_padlock">
  <material name="solid_brass">
    <color rgba="0.73 0.6 0.23 1" />
    </material>
  <material name="hardened_steel">
    <color rgba="0.8 0.82 0.85 1" />
    </material>
  <material name="graphite_black">
    <color rgba="0.1 0.1 0.11 1" />
    </material>
  <link name="body">
    <inertial>
      <origin xyz="0 0 0.0275" rpy="0 0 0" />
      <mass value="0.34" />
      <inertia ixx="9.94217e-05" ixy="0" ixz="0" iyy="0.000145662" iyz="0" izz="7.36667e-05" />
      </inertial>
    <visual name="body_shell">
      <geometry>
        <mesh filename="assets/meshes/padlock_body.obj" />
        </geometry>
      <material name="solid_brass">
        <color rgba="0.73 0.6 0.23 1" />
        </material>
      </visual>
    <visual name="bottom_plate">
      <origin xyz="0 0 0.0015" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.0198 0.003" />
        </geometry>
      <material name="hardened_steel">
        <color rgba="0.8 0.82 0.85 1" />
        </material>
      </visual>
    <visual name="front_face_plate">
      <origin xyz="0 0.0106 0.029" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.0012 0.034" />
        </geometry>
      <material name="hardened_steel">
        <color rgba="0.8 0.82 0.85 1" />
        </material>
      </visual>
    <visual name="key_plug">
      <origin xyz="0 0.0109 0.0195" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0082" length="0.0024" />
        </geometry>
      <material name="hardened_steel">
        <color rgba="0.8 0.82 0.85 1" />
        </material>
      </visual>
    <visual name="key_slot">
      <origin xyz="0 0.0111 0.0198" rpy="0 0 0" />
      <geometry>
        <box size="0.002 0.0026 0.0105" />
        </geometry>
      <material name="graphite_black">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    <visual name="ward_notch">
      <origin xyz="0 0.0111 0.0167" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.0026 0.0018" />
        </geometry>
      <material name="graphite_black">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    <visual name="left_bore">
      <origin xyz="-0.013 0 0.049" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0044" length="0.012" />
        </geometry>
      <material name="graphite_black">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    <visual name="right_bore">
      <origin xyz="0.013 0 0.049" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0044" length="0.012" />
        </geometry>
      <material name="graphite_black">
        <color rgba="0.1 0.1 0.11 1" />
        </material>
      </visual>
    </link>
  <link name="shackle">
    <inertial>
      <origin xyz="0.013 0 0.019" rpy="0 0 0" />
      <mass value="0.08" />
      <inertia ixx="1.00533e-05" ixy="0" ixz="0" iyy="1.68867e-05" iyz="0" izz="7.68667e-06" />
      </inertial>
    <visual name="shackle_rod">
      <geometry>
        <mesh filename="assets/meshes/padlock_shackle.obj" />
        </geometry>
      <material name="hardened_steel">
        <color rgba="0.8 0.82 0.85 1" />
        </material>
      </visual>
    </link>
  <joint name="shackle_hinge" type="revolute">
    <origin xyz="-0.013 0 0.055" rpy="0 0 0" />
    <parent link="body" />
    <child link="shackle" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="2.5" lower="0" upper="1.7" />
    </joint>
  </robot>
